---
import { FORM_IDS } from '../content/formRegistry';

interface Symptom {
  title: string;
  desc: string;
  review?: { text: string; author: string; };
}

interface Props {
  heading: string;
  subheading?: string;
  symptoms: Symptom[];
  phone?: string;
  servicePreset?: string;
  formId?: string;
}

const {
  heading,
  subheading,
  symptoms = [],
  phone = '',
  servicePreset = 'AC Repair',
  formId,
} = Astro.props;

const isValidForm = formId && (FORM_IDS as readonly string[]).includes(formId);
const sgFormId = formId ? `sg-${formId}` : 'sg-contact-form';
---

<section class="sg-section" id="warning-signs">
  <div class="sg-container">

    <!-- LEFT: Accordion -->
    <div class="sg-left">
      <span class="sg-eyebrow">Diagnose The Problem</span>
      <h2 class="sg-heading">{heading}</h2>
      {subheading && <p class="sg-subheading">{subheading}</p>}

      <div class="sg-accordion">
        {symptoms.map((sym, i) => (
          <details class="sg-item" name="symptoms" open={i === 0}>
            <summary class="sg-summary">
              <span class="sg-icon" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                  <line x1="12" y1="9" x2="12" y2="13"/>
                  <line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
              </span>
              <span class="sg-title">{sym.title}</span>
              <span class="sg-chevron" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </span>
            </summary>
            <div class="sg-body">
              <p>{sym.desc}</p>
            </div>
          </details>
        ))}
      </div>
    </div>

    <!-- RIGHT: Contact Form -->
    <div class="sg-right">
      <div class="sg-form-card">
        <div class="sg-form-header">
          <span class="sg-form-eyebrow">Free Service Call Evaluation</span>
          <h3 class="sg-form-heading">Get a Tech Out Today</h3>
          <p class="sg-form-sub">Tell us what's going on — we'll dispatch a tech same-day.</p>
        </div>

        {!isValidForm ? (
          <div class="form-unassigned-warning">
            <div class="form-warn-icon">⚠️</div>
            <h3 class="form-warn-title">Form Not Configured</h3>
            <p class="form-warn-body">This page has no <code>formId</code> set. No form will appear here until one is chosen.</p>
            <p class="form-warn-label">Set one of these in the page <code>.md</code> file:</p>
            <ul class="form-warn-list">
              <li><code>formId: "contact-form-fort-lauderdale"</code></li>
              <li><code>formId: "contact-form-tampa"</code></li>
              <li><code>formId: "contact-form-fort-myers"</code></li>
              <li><code>formId: "contact-form-orlando"</code></li>
            </ul>
            <p class="form-warn-footer">To add a new location form, edit <code>src/content/formRegistry.ts</code> first.</p>
          </div>
        ) : (
        <>
        <!-- REAL FORM — same name as FiftyFiftyForm, unique id. WhatConverts tracks by Name. -->
        <form class="sg-form" id={sgFormId} name={formId}
              data-netlify="true" netlify-honeypot="bot-field" method="POST" action="/">
          <input type="hidden" name="form-name" value={formId} />
          <input type="hidden" name="contact-service" value={servicePreset} />

          <p class="hidden" style="display:none"><label>Don't fill this out: <input name="bot-field" /></label></p>

          <div class="sg-field">
            <label for="sg-name">Your Name</label>
            <input type="text" name="contact-name" id="sg-name" placeholder="Full Name" required autocomplete="name" />
          </div>

          <div class="sg-field">
            <label for="sg-email">Email Address</label>
            <input type="email" name="contact-email" id="sg-email" placeholder="you@email.com" required autocomplete="email" />
          </div>

          <div class="sg-field">
            <label for="sg-phone">Phone Number</label>
            <input type="tel" name="contact-phone" id="sg-phone" placeholder="(954) 555-0100" required autocomplete="tel" />
          </div>

          <div class="sg-field">
            <label for="sg-zip">Zip Code</label>
            <input type="text" name="contact-zip" id="sg-zip" placeholder="33301" required autocomplete="postal-code" inputmode="numeric" maxlength="5" />
          </div>

          <div class="sg-field">
            <label for="sg-issue">What's happening? <span>(optional)</span></label>
            <select name="contact-issue" id="sg-issue">
              <option value="">Select a symptom...</option>
              {symptoms.map(sym => (
                <option value={sym.title}>{sym.title}</option>
              ))}
              <option value="Other">Something else</option>
            </select>
          </div>

          <button type="submit" class="sg-submit">
            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.52 2 2 0 0 1 3.6 1.36h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            Book My Same-Day Repair
          </button>

          <div class="sg-trust">
            <span>⭐⭐⭐⭐⭐</span>
            <span>4.9 · 1,100+ Google Reviews</span>
          </div>
        </form>

        {phone && (
          <a href={`tel:${phone.replace(/\D/g,'')}`} class="sg-call-link">
            <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.52 2 2 0 0 1 3.6 1.36h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Or call us directly: {phone}
          </a>
        )}
        </>
        )}
      </div>
    </div>

  </div>
</section>

<style>
/* ── Form Not Configured Warning ─────────────────────────────── */
.form-unassigned-warning {
  background: #fffbeb;
  border: 3px dashed #f59e0b;
  border-radius: 12px;
  padding: 2rem 1.5rem;
  text-align: center;
}
.form-warn-icon { font-size: 2.5rem; margin-bottom: 0.75rem; }
.form-warn-title { font-family: var(--font-heading); font-size: 1.1rem; font-weight: 800; color: #92400e; margin-bottom: 0.5rem; }
.form-warn-body { font-size: 0.85rem; color: #78350f; margin-bottom: 0.75rem; line-height: 1.6; }
.form-warn-label { font-size: 0.8rem; font-weight: 700; color: #92400e; margin-bottom: 0.4rem; }
.form-warn-list { list-style: none; padding: 0; margin: 0 0 0.75rem; display: flex; flex-direction: column; gap: 0.3rem; text-align: left; }
.form-warn-list li code { display: block; background: #fef3c7; border: 1px solid #fbbf24; border-radius: 6px; padding: 0.3rem 0.6rem; font-size: 0.75rem; color: #78350f; font-family: monospace; }
.form-warn-footer { font-size: 0.75rem; color: #92400e; margin: 0; }
.form-warn-footer code { background: #fef3c7; padding: 0.1rem 0.3rem; border-radius: 4px; }

/* ── Section wrapper ── */
.sg-section {
  background: #f8fafc;
  padding: 5rem 1.5rem;
  border-top: 1px solid #E5E7EB;
  border-bottom: 1px solid #E5E7EB;
  overflow: hidden;
}

.sg-container {
  max-width: 1180px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 420px;
  gap: 4rem;
  align-items: start;
}

/* ── LEFT ── */
.sg-left {}

.sg-eyebrow {
  display: inline-block;
  font-size: 0.72rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--color-accent);
  margin-bottom: 0.75rem;
}

.sg-heading {
  font-family: var(--font-heading);
  font-size: clamp(1.5rem, 2.8vw, 2.1rem);
  font-weight: 800;
  color: var(--color-heading);
  line-height: 1.2;
  margin-bottom: 0.75rem;
}

.sg-subheading {
  font-size: 0.95rem;
  color: var(--color-text-muted);
  line-height: 1.6;
  margin-bottom: 2rem;
}

/* ── Accordion ── */
.sg-accordion {
  display: flex;
  flex-direction: column;
  gap: 0;
  border: 1px solid #E5E7EB;
  border-radius: 14px;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 4px 20px rgba(0,0,0,0.04);
}

.sg-item {
  border-bottom: 1px solid #E5E7EB;
}
.sg-item:last-child { border-bottom: none; }

.sg-summary {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 1rem 1.25rem;
  cursor: pointer;
  list-style: none;
  user-select: none;
  transition: background 0.15s ease;
}
.sg-summary::-webkit-details-marker { display: none; }
.sg-summary:hover { background: #fef9f5; }

.sg-item[open] .sg-summary {
  background: #fef9f5;
  border-bottom: 1px solid #f0e4d4;
}

.sg-icon {
  flex-shrink: 0;
  width: 28px;
  height: 28px;
  min-width: 28px;
  border-radius: 7px;
  background: rgba(246, 138, 30, 0.1);
  color: var(--color-accent);
  display: flex;
  align-items: center;
  justify-content: center;
}
.sg-icon svg {
  width: 14px;
  height: 14px;
  display: block;
  flex-shrink: 0;
}

.sg-title {
  flex: 1;
  font-family: var(--font-heading);
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--color-heading);
}

.sg-chevron {
  flex-shrink: 0;
  color: var(--color-text-muted);
  transition: transform 0.2s ease;
  display: flex;
  align-items: center;
  width: 16px;
  height: 16px;
}
.sg-chevron svg {
  width: 16px;
  height: 16px;
  display: block;
  flex-shrink: 0;
}
.sg-item[open] .sg-chevron { transform: rotate(180deg); }

.sg-body {
  padding: 0 1.25rem 1rem 3.5rem;
}
.sg-body p {
  font-size: 0.875rem;
  color: var(--color-text-muted);
  line-height: 1.65;
  margin: 0;
}

/* ── RIGHT: Form card ── */
.sg-right {
  position: sticky;
  top: 100px;
}

.sg-form-card {
  background: #fff;
  border: 1px solid #E5E7EB;
  border-radius: 16px;
  padding: 2rem;
  box-shadow: 0 8px 32px rgba(0,0,0,0.08);
}

.sg-form-eyebrow {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--color-accent);
  margin-bottom: 0.5rem;
}

.sg-form-heading {
  font-family: var(--font-heading);
  font-size: 1.4rem;
  font-weight: 800;
  color: var(--color-heading);
  line-height: 1.2;
  margin-bottom: 0.4rem;
}

.sg-form-sub {
  font-size: 0.85rem;
  color: var(--color-text-muted);
  line-height: 1.5;
  margin-bottom: 1.5rem;
}

.sg-form {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.sg-field {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.sg-field label {
  font-size: 0.78rem;
  font-weight: 700;
  color: var(--color-heading);
  letter-spacing: 0.02em;
}
.sg-field label span {
  font-weight: 400;
  color: var(--color-text-muted);
}

.sg-field input,
.sg-field select {
  width: 100%;
  padding: 0.75rem 1rem;
  border: 1.5px solid #E5E7EB;
  border-radius: 10px;
  font-size: 0.9rem;
  color: var(--color-text);
  background: #fff;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
  outline: none;
  font-family: inherit;
}
.sg-field input:focus,
.sg-field select:focus {
  border-color: var(--color-accent);
  box-shadow: 0 0 0 3px rgba(246,138,30,0.12);
}

.sg-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  width: 100%;
  padding: 0.9rem 1.5rem;
  background: var(--color-accent);
  color: #fff;
  font-family: var(--font-heading);
  font-size: 0.95rem;
  font-weight: 800;
  border: none;
  border-radius: 10px;
  cursor: pointer;
  box-shadow: 0 6px 20px rgba(246,138,30,0.35);
  transition: all 0.2s ease;
  letter-spacing: 0.01em;
  margin-top: 0.25rem;
}
.sg-submit:hover {
  background: #e07a15;
  transform: translateY(-2px);
  box-shadow: 0 10px 28px rgba(246,138,30,0.45);
}

.sg-trust {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  font-size: 0.75rem;
  color: var(--color-text-muted);
  margin-top: 0.25rem;
}

.sg-call-link {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-top: 1.25rem;
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--color-primary);
  text-decoration: none;
  text-align: center;
}
.sg-call-link:hover { color: var(--color-accent); }

/* ── Responsive ── */
@media (max-width: 900px) {
  .sg-container {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  .sg-right { position: static; }
}

@media (max-width: 480px) {
  .sg-section { padding: 3rem 1rem; }
}
</style>
