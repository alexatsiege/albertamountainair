---
// FloatingCallButton.astro — Global floating CTA button pinned to bottom right
interface Props {
  phone: string;
}
const { phone } = Astro.props;
const cleanPhone = phone.replace(/\D/g, '');
---

<a href={`tel:${cleanPhone}`} class="floating-call-btn" aria-label={`Call ${phone}`}>
  <div class="floating-call-icon">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
    </svg>
  </div>
  <div class="floating-call-labels">
    <span class="floating-call-text">Call Now</span>
    <span class="floating-call-number">{phone}</span>
  </div>
</a>

<style>
.floating-call-btn {
  position: fixed;
  bottom: 32px;
  right: 32px;
  z-index: 9000;
  display: flex;
  align-items: center;
  gap: 16px;
  background: var(--color-primary);
  color: white;
  text-decoration: none;
  padding: 14px 30px 14px 14px;
  border-radius: 9999px;
  box-shadow: 0 10px 25px -5px rgba(0,0,0,0.3), 0 8px 10px -6px rgba(0,0,0,0.2);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 2px solid rgba(255,255,255,0.15);
}

.floating-call-btn::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  border-radius: 9999px;
  z-index: -1;
  animation: pulse-ring 2.5s cubic-bezier(0.215, 0.61, 0.355, 1) infinite;
}

@keyframes pulse-ring {
  0%   { box-shadow: 0 0 0 0px var(--color-primary); opacity: 0.6; }
  70%  { box-shadow: 0 0 0 18px var(--color-primary); opacity: 0; }
  100% { box-shadow: 0 0 0 0px var(--color-primary); opacity: 0; }
}

.floating-call-btn:hover {
  transform: translateY(-4px) scale(1.03);
  background: var(--color-accent);
  border-color: rgba(0,0,0,0.1);
  box-shadow: 0 20px 25px -5px rgba(0,0,0,0.4), 0 10px 10px -5px rgba(0,0,0,0.2);
}
.floating-call-btn:hover::before { animation: none; }
.floating-call-btn:hover .floating-call-icon {
  background: rgba(255,255,255,0.25);
  animation: none;
}

.floating-call-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52px;
  height: 52px;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  color: white;
  flex-shrink: 0;
  transition: all 0.3s ease;
  animation: ring-phone 4s cubic-bezier(0.36, 0.07, 0.19, 0.97) infinite;
}

@keyframes ring-phone {
  0%, 15%, 100% { transform: rotate(0deg); }
  2%  { transform: rotate(15deg) scale(1.1); }
  4%  { transform: rotate(-12deg) scale(1.1); }
  6%  { transform: rotate(15deg) scale(1.1); }
  8%  { transform: rotate(-12deg) scale(1.1); }
  10% { transform: rotate(15deg) scale(1.1); }
  12% { transform: rotate(-12deg) scale(1.1); }
}

/* Labels */
.floating-call-labels {
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.floating-call-text {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 0.78rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  opacity: 0.85;
  line-height: 1;
}

.floating-call-number {
  font-family: var(--font-heading);
  font-weight: 900;
  font-size: 1.2rem;
  letter-spacing: 0.01em;
  white-space: nowrap;
  line-height: 1;
}

/* ── Mobile: compact icon pill ── */
@media (max-width: 768px) {
  .floating-call-btn {
    bottom: 80px; /* above mobile sticky bar */
    right: 16px;
    padding: 12px;
    border-radius: 50%;
    gap: 0;
  }
  .floating-call-labels { display: none; }
  .floating-call-icon {
    width: 38px;
    height: 38px;
    background: transparent;
  }
}
</style>
