---
// TrustBar.astro — Clean post-hero trust strip for PPC pages
// Replaces the trust badges and value props that were cluttering the hero

interface Props {
  googleRating?: number;
  googleReviewCount?: number;
  phone?: string;
  yearsInBusiness?: number;
}

const {
  googleRating,
  googleReviewCount,
  phone,
  yearsInBusiness = 10,
} = Astro.props;
---

<div class="trust-bar" id="trust-bar">
  <div class="trust-bar-inner">

    <!-- Google Rating -->
    {googleRating && googleReviewCount && (
      <>
        <div class="tb-item">
          <div class="tb-icon tb-icon--google">
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
              <path fill="#4285F4" d="M23.745 12.27c0-.79-.07-1.54-.19-2.27h-11.3v4.51h6.47c-.29 1.48-1.14 2.73-2.4 3.58v3h3.86c2.26-2.09 3.56-5.17 3.56-8.82z"/>
              <path fill="#34A853" d="M12.255 24c3.24 0 5.95-1.08 7.93-2.91l-3.86-3c-1.08.72-2.45 1.16-4.07 1.16-3.13 0-5.78-2.11-6.73-4.96h-3.98v3.09C3.515 21.3 7.615 24 12.255 24z"/>
              <path fill="#FBBC05" d="M5.525 14.29c-.25-.72-.38-1.49-.38-2.29s.14-1.57.38-2.29V6.62h-3.98a11.86 11.86 0 0 0 0 10.76l3.98-3.09z"/>
              <path fill="#EA4335" d="M12.255 4.75c1.77 0 3.35.61 4.6 1.8l3.42-3.42C18.205 1.19 15.495 0 12.255 0c-4.64 0-8.74 2.7-10.71 6.62l3.98 3.09c.95-2.85 3.6-4.96 6.73-4.96z"/>
            </svg>
          </div>
          <div class="tb-text">
            <span class="tb-stars">★★★★★</span>
            <span class="tb-label"><strong>{googleRating}/5</strong> · {googleReviewCount}+ Google Reviews</span>
          </div>
        </div>

        <div class="tb-divider" aria-hidden="true"></div>
      </>
    )}

    <!-- Local -->
    <div class="tb-item">
      <div class="tb-icon tb-icon--bbb">
        <span>LOCAL</span>
      </div>
      <div class="tb-text">
        <span class="tb-badge-label">Local Service</span>
        <span class="tb-label">Fast response from a nearby team</span>
      </div>
    </div>

    <div class="tb-divider" aria-hidden="true"></div>

    <!-- Licensed -->
    <div class="tb-item">
      <div class="tb-icon tb-icon--shield">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          <polyline points="9 12 11 14 15 10"/>
        </svg>
      </div>
      <div class="tb-text">
        <span class="tb-badge-label">Licensed & Insured</span>
        <span class="tb-label">Professional heating and cooling service</span>
      </div>
    </div>

    <div class="tb-divider" aria-hidden="true"></div>

    <!-- Same Day -->
    <div class="tb-item">
      <div class="tb-icon tb-icon--bolt">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18" aria-hidden="true">
          <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
        </svg>
      </div>
      <div class="tb-text">
        <span class="tb-badge-label">Same-Day Service</span>
        <span class="tb-label">Emergency help available when you need it</span>
      </div>
    </div>

    <div class="tb-divider" aria-hidden="true"></div>

    <!-- Years -->
    <div class="tb-item">
      <div class="tb-icon tb-icon--years">
        <span>{yearsInBusiness}+</span>
      </div>
      <div class="tb-text">
        <span class="tb-badge-label">Years of Experience</span>
        <span class="tb-label">Family-Owned & Operated</span>
      </div>
    </div>

  </div>
</div>

<style>
.trust-bar {
  background: #fff;
  border-bottom: 1px solid #E5E7EB;
  box-shadow: 0 4px 24px rgba(0,0,0,0.07);
  position: relative;
  z-index: 10;
}

.trust-bar-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1.5rem;
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 0;
}

.tb-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 1.1rem 1rem;
  flex: 1;
  min-width: 0;
}

.tb-divider {
  width: 1px;
  background: #E5E7EB;
  align-self: stretch;
  margin: 12px 0;
}

/* Icon containers */
.tb-icon {
  width: 38px;
  height: 38px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tb-icon--google {
  background: #F8F9FA;
  border: 1px solid #E5E7EB;
}

.tb-icon--bbb {
  background: #003F87;
  color: white;
  font-size: 0.7rem;
  font-weight: 900;
  font-family: var(--font-heading);
  letter-spacing: 0.05em;
}

.tb-icon--shield {
  background: rgba(41, 176, 229, 0.1);
  color: var(--color-primary);
}

.tb-icon--bolt {
  background: rgba(246, 138, 30, 0.1);
  color: var(--color-accent);
}

.tb-icon--years {
  background: var(--color-primary-ultra-light);
  color: var(--color-primary);
  font-size: 0.9rem;
  font-weight: 900;
  font-family: var(--font-heading);
}

/* Text */
.tb-text {
  display: flex;
  flex-direction: column;
  gap: 1px;
  min-width: 0;
}

.tb-stars {
  color: #FBBF24;
  font-size: 0.75rem;
  line-height: 1;
  letter-spacing: 1px;
}

.tb-badge-label {
  display: block;
  font-family: var(--font-heading);
  font-size: 0.82rem;
  font-weight: 800;
  color: var(--color-text);
  line-height: 1.2;
  overflow-wrap: break-word;
}

.tb-label {
  display: block;
  font-size: 0.72rem;
  color: var(--color-text-muted);
  line-height: 1.3;
  overflow-wrap: break-word;
}

/* Responsive */

/* At medium sizes — switch to 3+2 wrapping grid before things get squeezed */
@media (max-width: 1100px) {
  .trust-bar-inner {
    flex-wrap: wrap;
    justify-content: center;
    gap: 0;
  }
  .tb-item {
    flex: 0 0 calc(33.333% - 1px);
    padding: 1rem 0.75rem;
    border-bottom: 1px solid #E5E7EB;
  }
  .tb-item:nth-child(1),
  .tb-item:nth-child(3),
  .tb-item:nth-child(5),
  .tb-item:nth-child(7) {
    border-right: 1px solid #E5E7EB;
  }
  .tb-divider { display: none; }
}

@media (max-width: 768px) {
  .trust-bar-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }
  .tb-divider { display: none; }
  .tb-item {
    flex: unset;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid #E5E7EB;
    border-right: none !important;
  }
  .tb-item:nth-child(odd) {
    border-right: 1px solid #E5E7EB !important;
  }
  .tb-item:nth-last-child(-n+2) {
    border-bottom: none;
  }
}
</style>
