---
// CTA.astro — Redesigned High-End Glassmorphic CTA Module
import { Image } from 'astro:assets';

interface Props {
  heading?: string;
  subheading?: string;
  phone: string;
  navCTA?: string;
  navCtaUrl?: string;
  clientName?: string;
  townName?: string;
  truckSrc?: string;
  logoSrc?: string;
}

const {
  heading = "Ready for a Comfortable Home All Year Round?",
  subheading = "Don't wait until your system breaks down. Call us today for fast, honest service from our expert engineering team.",
  phone,
  navCTA = "Get a Free Quote",
  navCtaUrl = "/contact",
  clientName = "Your Company",
  townName = "Calgary",
  truckSrc,
  logoSrc = "/_assets/Logo icon-5.png",
} = Astro.props;

const phoneRaw = phone.replace(/\D/g, '');
---

<section class="cta-section" id="cta">
  <!-- Background image + overlay -->
  {truckSrc && (
    <div class="cta-bg" aria-hidden="true">
      <img src={truckSrc} alt="" class="cta-bg-img" />
      <div class="cta-bg-overlay"></div>
    </div>
  )}

  <!-- Concept 2: Airflow sweep background -->
  <div class="cta-airflow" aria-hidden="true">
    <div class="cta-lane"><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span></div>
    <div class="cta-lane"><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span></div>
    <div class="cta-lane"><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span></div>
    <div class="cta-lane"><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span></div>
    <div class="cta-lane"><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span></div>
    <div class="cta-lane"><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span><span>›</span></div>
  </div>

  <!-- Ambient Light Orbs -->
  <div class="cta-orb orb-red"></div>
  <div class="cta-orb orb-blue"></div>

  <!-- The Main Glassmorphic Card -->
  <div class="cta-glass-card glass-reveal">
    <div class="cta-card-inner">
      <div class="cta-badge-row">
         <span class="cta-badge">Schedule a Free Consultation</span>
      </div>
      
      <h2 class="cta-heading">{heading}</h2>
      <p class="cta-desc">{subheading}</p>

      <div class="cta-actions">
        <!-- Concept 5: Pulsing chevron rings behind button -->
        <div class="cta-btn-wrap">
          <span class="cta-ring r1"></span>
          <span class="cta-ring r2"></span>
          <span class="cta-ring r3"></span>
          <a href={`tel:${phoneRaw}`} class="btn-cta pulse-btn">
            Call {phone}
            <svg viewBox="0 0 24 24">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.52 2 2 0 0 1 3.6 1.36h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.73 16.92z"/>
            </svg>
          </a>
        </div>
        <a href={navCtaUrl} class="btn-secondary">
          {navCTA}
          <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Trust Indicator Bar -->
      <div class="cta-trust">
        <div class="trust-stars">
          <svg viewBox="0 0 24 24" fill="#FBBF24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <svg viewBox="0 0 24 24" fill="#FBBF24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <svg viewBox="0 0 24 24" fill="#FBBF24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <svg viewBox="0 0 24 24" fill="#FBBF24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <svg viewBox="0 0 24 24" fill="#FBBF24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        </div>
        <p><strong>4.9/5 Average Rating</strong> from over 1,100+ satisfied homeowners.</p>
      </div>

    </div>
  </div>
</section>

<style>
.cta-section {
  position: relative;
  background: var(--color-primary-dark, #0f172a);
  padding: 8rem 1.5rem;
  overflow: hidden;
  display: flex; align-items: center; justify-content: center;
}

/* Background photo */
.cta-bg {
  position: absolute; inset: 0;
  z-index: 0;
  pointer-events: none;
}
.cta-bg-img {
  width: 100%; height: 100%;
  object-fit: cover;
  object-position: center 30%;
  opacity: 0.60;
}
.cta-bg-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(
    135deg,
    rgba(7, 24, 40, 0.65) 0%,
    rgba(15, 34, 64, 0.40) 50%,
    rgba(7, 24, 40, 0.70) 100%
  );
}

/* Airflow sweep background (Concept 2) */
.cta-airflow {
  position: absolute; inset: 0; overflow: hidden;
  display: flex; flex-direction: column; justify-content: space-evenly;
  z-index: 1; pointer-events: none;
}
.cta-lane {
  display: flex; white-space: nowrap;
  animation: cta-sweep 6s linear infinite;
  opacity: 0.5;
}
.cta-lane:nth-child(2) { animation-duration: 8s; animation-delay: -2s; opacity: 0.3; }
.cta-lane:nth-child(3) { animation-duration: 5s; animation-delay: -1s; opacity: 0.2; }
.cta-lane:nth-child(4) { animation-duration: 9s; animation-delay: -4s; opacity: 0.35; }
.cta-lane:nth-child(5) { animation-duration: 7s; animation-delay: -3s; opacity: 0.25; }
.cta-lane:nth-child(6) { animation-duration: 10s; animation-delay: -5s; opacity: 0.18; }
.cta-lane span { font-size: 1.8rem; font-weight: 900; color: var(--color-primary); margin-right: 20px; }
.cta-lane:nth-child(even) span { color: var(--color-accent); }
@keyframes cta-sweep { 0% { transform: translateX(-50%); } 100% { transform: translateX(0%); } }

/* Ambient Color Orbs */
.cta-orb {
  position: absolute; border-radius: 50%; filter: blur(90px); opacity: 0.5; z-index: 2;
  will-change: transform;
}
.orb-red {
  width: 400px; height: 400px; background: var(--color-accent);
  top: -100px; left: -100px;
  animation: floatRed 10s ease-in-out infinite alternate;
}
.orb-blue {
  width: 500px; height: 500px; background: var(--color-primary);
  bottom: -150px; right: -150px;
  animation: floatBlue 12s ease-in-out infinite alternate;
}
@keyframes floatRed { 0% { transform: translate(0, 0); } 100% { transform: translate(100px, 50px); } }
@keyframes floatBlue { 0% { transform: translate(0, 0); } 100% { transform: translate(-100px, -80px); } }

/* Glassmorphic Container */
.cta-glass-card {
  position: relative; z-index: 10;
  max-width: 900px; width: 100%;
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(28px); -webkit-backdrop-filter: blur(28px);
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-top: 1px solid rgba(255, 255, 255, 0.35);
  border-radius: 32px;
  box-shadow: 0 30px 60px rgba(0,0,0,0.4), inset 0 0 0 1px rgba(255,255,255,0.05);
  text-align: center; color: #fff;
  transition: transform 0.4s ease, box-shadow 0.4s ease;
}
.cta-glass-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 40px 80px rgba(0,0,0,0.5), inset 0 0 0 1px rgba(255,255,255,0.1);
  border-top: 1px solid rgba(255,255,255,0.5);
}

.cta-card-inner {
  padding: 4.5rem 3.5rem;
}

/* Badge */
.cta-badge-row { margin-bottom: 1.5rem; }
.cta-badge {
  display: inline-block;
  background: var(--color-accent); color: #fff;
  font-family: var(--font-heading); font-size: 0.8rem; font-weight: 800;
  letter-spacing: 0.08em; text-transform: uppercase;
  padding: 8px 20px; border-radius: 50px;
  box-shadow: 0 6px 16px rgba(218, 26, 50, 0.4);
}

/* Typography */
.cta-heading {
  font-family: var(--font-heading);
  font-size: clamp(2.2rem, 5vw, 3.5rem);
  font-weight: 800; line-height: 1.1;
  margin-bottom: 1.5rem; letter-spacing: -0.02em;
  text-shadow: 0 4px 12px rgba(0,0,0,0.15);
}
.cta-desc {
  font-size: 1.15rem; color: rgba(255,255,255,0.85);
  max-width: 680px; margin: 0 auto 2.5rem;
  line-height: 1.7; font-weight: 500;
}

/* Buttons */
.cta-actions {
  display: flex; align-items: center; justify-content: center;
  gap: 16px; flex-wrap: wrap; margin-bottom: 3rem;
}

.btn-cta {
  display: inline-flex; align-items: center; justify-content: center; gap: 0.6rem;
  font-family: var(--font-heading); font-size: 1.125rem; font-weight: 800;
  padding: 16px 36px; border-radius: 50px; text-decoration: none;
  background: var(--color-accent); color: #fff;
  box-shadow: 0 8px 24px rgba(218, 26, 50, 0.4);
  transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  border: none; cursor: pointer;
}
.btn-cta svg {
  width: 20px; height: 20px; fill: none; stroke: currentColor;
  stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;
  transition: transform 0.25s ease;
}
.btn-cta:hover { transform: translateY(-3px) scale(1.02); box-shadow: 0 12px 32px rgba(218, 26, 50, 0.6); }
.btn-cta:hover svg { transform: translateX(3px) rotate(5deg); }

/* Concept 5: Pulsing ring wrapper */
.cta-btn-wrap { position: relative; display: inline-flex; align-items: center; justify-content: center; }
.cta-ring {
  position: absolute; border-radius: 50px;
  border: 2px solid var(--color-accent);
  width: 100%; height: 100%;
  animation: cta-ring-pulse 2.4s ease-out infinite;
  pointer-events: none;
}
.cta-ring.r2 { animation-delay: 0.8s; border-color: var(--color-primary); }
.cta-ring.r3 { animation-delay: 1.6s; }
@keyframes cta-ring-pulse {
  0%   { transform: scale(1); opacity: 0.7; }
  100% { transform: scale(1.7); opacity: 0; }
}

/* Pulse animation on primary button */
.pulse-btn { animation: pulse-ring 2.5s infinite; }
@keyframes pulse-ring {
  0%   { box-shadow: 0 0 0 0 rgba(246, 138, 30, 0.55); }
  70%  { box-shadow: 0 0 0 16px rgba(246, 138, 30, 0); }
  100% { box-shadow: 0 0 0 0 rgba(246, 138, 30, 0); }
}

.btn-secondary {
  display: inline-flex; align-items: center; gap: 0.5rem;
  font-family: var(--font-heading); font-size: 1.05rem; font-weight: 700;
  padding: 14px 32px; border-radius: 50px; text-decoration: none;
  background: rgba(255,255,255,0.08); color: #fff;
  border: 1.5px solid rgba(255,255,255,0.25);
  transition: all 0.25s ease; backdrop-filter: blur(8px);
}
.btn-secondary svg {
  width: 18px; height: 18px; fill: none; stroke: currentColor;
  stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;
  transition: transform 0.25s ease;
}
.btn-secondary:hover { background: rgba(255,255,255,0.18); transform: translateY(-2px); border-color: rgba(255,255,255,0.4); }
.btn-secondary:hover svg { transform: translateX(3px); }

/* Trust Content */
.cta-trust {
  display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px;
  border-top: 1px solid rgba(255, 255, 255, 0.15);
  padding-top: 2rem;
}
.trust-stars {
  display: flex; gap: 4px;
}
.trust-stars svg {
  width: 24px; height: 24px; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
}
.cta-trust p {
  margin: 0; font-size: 0.95rem; color: rgba(255,255,255,0.8);
}
.cta-trust p strong {
  color: #fff; font-weight: 700;
}

@media (max-width: 768px) {
  .cta-section { padding: 5rem 1rem; }
  .cta-card-inner { padding: 3rem 1.5rem; }
  .cta-heading { font-size: 2.2rem; }
  .btn-cta, .btn-secondary { width: 100%; }
}
</style>

<script>
  const cta = document.querySelector('.cta-glass-card');
  if (cta) {
    const obs = new IntersectionObserver(([e]) => {
      if (e.isIntersecting) { cta.classList.add('is-visible'); obs.disconnect(); }
    }, { threshold: 0.2 });
    obs.observe(cta);
  }
</script>
