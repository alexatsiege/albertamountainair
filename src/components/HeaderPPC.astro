---
// HeaderPPC.astro — Simplified PPC landing page header
// Logo + Phone + CTA only. No navigation links to eliminate exit paths.
// Sticky on scroll for persistent conversion opportunities.

interface Props {
  businessName: string;
  phone: string;
  navCTA: string;
  navCtaUrl: string;
  logoSrc?: string;
}

const { businessName, phone, navCTA, navCtaUrl, logoSrc } = Astro.props;
---

<div class="ppc-header" id="ppc-header">
  <div class="ppc-header-inner">

    <!-- Logo -->
    <a href="#hero" class="ppc-logo" aria-label={businessName}>
      {logoSrc
        ? <img src={logoSrc} alt={`${businessName} logo`} />
        : <span class="ppc-logo-text">{businessName}</span>
      }
    </a>

    <!-- Phone + CTA -->
    <div class="ppc-header-actions">
      <a href={`tel:${phone.replace(/\D/g, '')}`} class="ppc-phone">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.52 2 2 0 0 1 3.6 1.36h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.73 16.92z"/>
        </svg>
        <span class="ppc-phone-number">{phone}</span>
      </a>
      <a href={navCtaUrl} class="ppc-cta">{navCTA}</a>
    </div>

  </div>
</div>

<style>
.ppc-header {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 1000;
  padding: 8px 16px;
  transition: padding 200ms ease, box-shadow 200ms ease;
}
.ppc-header.is-scrolled {
  padding: 0 16px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.08);
}

.ppc-header-inner {
  max-width: 1280px;
  margin: 0 auto;
  background: #fff;
  border-radius: 0.75rem;
  padding: 10px 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  transition: border-radius 200ms ease;
}
.ppc-header.is-scrolled .ppc-header-inner {
  border-radius: 0 0 0.75rem 0.75rem;
  box-shadow: none;
}

/* Logo */
.ppc-logo {
  display: flex;
  align-items: center;
  text-decoration: none;
  flex-shrink: 0;
}
.ppc-logo img {
  height: 72px;
  width: auto;
  max-width: 260px;
  object-fit: contain;
  display: block;
}
.ppc-logo-text {
  font-family: var(--font-heading);
  font-size: 1.3rem;
  font-weight: 800;
  color: var(--color-primary);
}

/* Actions */
.ppc-header-actions {
  display: flex;
  align-items: center;
  gap: 16px;
}

/* Phone */
.ppc-phone {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-text, #1A1A2E);
  text-decoration: none;
  transition: color 150ms ease;
}
.ppc-phone:hover { color: var(--color-primary); }
.ppc-phone svg {
  width: 18px; height: 18px;
  color: var(--color-primary);
  flex-shrink: 0;
}
.ppc-phone-number {
  white-space: nowrap;
}

/* CTA Button */
.ppc-cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12px 28px;
  font-family: var(--font-heading);
  font-size: 0.9rem;
  font-weight: 700;
  color: #fff;
  background: var(--color-primary);
  border-radius: 9999px;
  text-decoration: none;
  white-space: nowrap;
  transition: all 200ms ease;
  box-shadow: 0 2px 8px rgba(37,99,235,0.2);
}
.ppc-cta:hover {
  background: var(--color-primary-dark, #1D4ED8);
  transform: translateY(-1px);
  box-shadow: 0 4px 14px rgba(37,99,235,0.3);
}

/* Mobile — logo + CTA button only */
@media (max-width: 600px) {
  .ppc-header-inner { padding: 8px 14px; }
  .ppc-logo img { height: 48px; max-width: 160px; }
  .ppc-phone { display: none; }
  .ppc-cta { padding: 10px 18px; font-size: 0.82rem; }
}
</style>

<script>
  const ppcHeader = document.getElementById('ppc-header');
  window.addEventListener('scroll', () => {
    ppcHeader?.classList.toggle('is-scrolled', window.scrollY > 50);
  });
</script>
