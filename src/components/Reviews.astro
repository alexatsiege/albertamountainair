---
// Reviews.astro — Exact match of v1 reviews-preview.html
// Carousel with prev/next arrows, dot indicators, Google-colored avatars, border-top accent
// Using Astro (no React) for direct CSS/HTML match with the v1 design

interface Review {
  name: string;
  text: string;
  date?: string;
  rating?: number;
  photo?: string;
}

interface Props {
  heading?: string;
  rating?: number;
  reviewCount?: number;
  reviews?: Review[];
}

const {
  heading = 'Real Reviews from Real Homeowners',
  rating = 4.9,
  reviewCount = 280,
  reviews = [
    { name: 'Sarah M.',  text: 'Called at 8am and they were at my door by 10. Fixed the furnace in under an hour. Incredibly professional and reasonably priced.', date: '2 weeks ago' },
    { name: 'Jason K.',  text: 'Best HVAC company in the area. Fair pricing, showed up on time, and the technician actually explained what was wrong. Will never call anyone else.', date: '1 month ago' },
    { name: 'Lisa P.',   text: 'Our AC went out on the hottest day of the summer and they had it fixed quickly. Professional, courteous, and reasonably priced. Cannot recommend enough!', date: '3 weeks ago' },
    { name: 'Mike R.',   text: 'Got three quotes for a new heat pump. Jay Moody was the most honest — they told me what I actually needed, not the most expensive option. Installed perfectly.', date: '2 months ago' },
    { name: 'Karen T.',  text: 'Annual tune-up service is worth every penny. Technician was thorough, polite, and left the area spotless. Our system runs better than it has in years.', date: '1 month ago' },
    { name: 'David H.',  text: 'Had them install a mini-split in our addition. Perfect job, cleaned up everything, and the Mass Save® rebate process was easier because they handled the paperwork.', date: '3 months ago' },
    { name: 'Amy W.',    text: 'Quick response, fair price, excellent work. The technician explained everything clearly and didn\'t try to upsell me on things I didn\'t need.', date: '5 weeks ago' },
    { name: 'Robert S.', text: 'They came out on a Sunday to help us with a heating issue — they were there within 2 hours. Reasonable pricing and honest service. This is the only HVAC company I\'ll ever call.', date: '2 months ago' },
  ],
} = Astro.props;

// Avatar colors matching v1 (google brand palette cycling)
const avatarColors = ['#4285F4','#EA4335','#34A853','#7C3AED','#FBBC05','#EC4899','#0EA5E9','#F97316'];

// Filter out any review that explicitly has less than 4 stars
const filteredReviews = reviews.filter(r => (r.rating ?? 5) >= 4);
---

<section class="reviews-section" id="reviews">
  <!-- Background decorative blobs -->
  <div class="reviews-accent-blob reviews-accent-blob-1" aria-hidden="true"></div>
  <div class="reviews-accent-blob reviews-accent-blob-2" aria-hidden="true"></div>
  <div class="reviews-accent-blob reviews-accent-blob-3" aria-hidden="true"></div>

  <div class="reviews-container">

    <!-- Section Header -->
    <div class="reviews-header">
      <span class="reviews-eyebrow">What Our Customers Say</span>
      <h2 class="reviews-heading">{heading}</h2>
      <div class="reviews-heading-accent">
        <span class="accent-line"></span>
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" class="accent-icon">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
        </svg>
        <span class="accent-line"></span>
      </div>

      <!-- Aggregate trust badge -->
      <div class="reviews-aggregate">
        <!-- Google G logo -->
        <svg class="aggregate-google-icon" viewBox="0 0 48 48">
          <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
          <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
          <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
          <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
        </svg>
        <div class="aggregate-info">
          <div class="aggregate-top-row">
            <span class="aggregate-rating">{rating}</span>
            <div class="aggregate-stars">
              {Array.from({ length: 5 }).map(() => (
                <svg viewBox="0 0 24 24" fill="#FBBC05" width="18" height="18">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01z"/>
                </svg>
              ))}
            </div>
          </div>
          <span class="aggregate-meta"><strong>{reviewCount}+ reviews</strong></span>
        </div>
      </div>
    </div>

    <!-- Carousel -->
    <div class="reviews-carousel-wrapper">
      <div class="carousel-btn prev disabled" id="prevBtn" aria-label="Previous reviews" role="button" tabindex="0">
        <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
      </div>

      <div class="reviews-track" id="reviewsTrack">
        {filteredReviews.map((review, i) => (
          <div class="review-card" style={`--avatar-bg: ${avatarColors[i % avatarColors.length]}`}>
            <div class="review-card-header">
              <div class="reviewer-avatar" style={`background: ${avatarColors[i % avatarColors.length]}; ${avatarColors[i % avatarColors.length] === '#FBBC05' ? 'color: #333;' : ''}`}>
                {review.name.charAt(0).toUpperCase()}
              </div>
              <div class="reviewer-info">
                <div class="reviewer-name">{review.name}</div>
                <div class="reviewer-meta">
                  <span class="review-date">{review.date || '1 month ago'}</span>
                </div>
              </div>
              <svg class="review-source-icon" viewBox="0 0 48 48">
                <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
              </svg>
            </div>
            <div class="review-stars">
              {Array.from({ length: review.rating ?? 5 }).map(() => (
                <svg viewBox="0 0 24 24" fill="#FBBC05" width="16" height="16">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01z"/>
                </svg>
              ))}
            </div>
            <div class="review-text-wrapper">
              <p class="review-text">"{review.text}"</p>
              {review.text.length > 180 && (
                <button class="read-more-btn" aria-expanded="false">Read more</button>
              )}
            </div>
            {review.photo && (
              <div class="review-photo-wrapper">
                <img src={review.photo} alt="Service job by Your Company" class="review-job-photo" loading="lazy" />
              </div>
            )}
          </div>
        ))}
      </div>

      <div class="carousel-btn next" id="nextBtn" aria-label="Next reviews" role="button" tabindex="0">
        <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
      </div>
    </div>

    <!-- Dots -->
    <div class="carousel-dots" id="carouselDots"></div>

  </div>
</section>

<style>
.reviews-section {
  background: var(--color-bg);
  padding: var(--space-12) var(--space-4);
  position: relative;
  overflow: hidden;
  border-top: 4px solid var(--color-primary);
}

/* Background decorative blobs */
.reviews-accent-blob {
  position: absolute; border-radius: 50%;
  pointer-events: none; z-index: 0;
}
.reviews-accent-blob-1 {
  width: 400px; height: 400px; top: -100px; left: -120px;
  background: radial-gradient(circle, rgba(37,99,235,0.08) 0%, transparent 70%);
  filter: blur(40px);
}
.reviews-accent-blob-2 {
  width: 350px; height: 350px; bottom: -80px; right: 10%;
  background: radial-gradient(circle, rgba(245,158,11,0.06) 0%, transparent 70%);
  filter: blur(35px);
}
.reviews-accent-blob-3 {
  width: 280px; height: 280px; top: 25%; right: -100px;
  background: radial-gradient(circle, rgba(37,99,235,0.06) 0%, transparent 70%);
  filter: blur(30px);
}

.reviews-container {
  max-width: 1200px; margin: 0 auto;
  position: relative; z-index: 1;
}

/* Section header */
.reviews-header { text-align: center; margin-bottom: var(--space-8); }

.reviews-eyebrow {
  display: inline-flex; align-items: center; gap: 0.5rem;
  font-size: var(--text-xs); font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.1em;
  color: var(--color-primary); margin-bottom: var(--space-3);
}

.reviews-heading {
  font-family: var(--font-heading); font-size: var(--text-4xl);
  font-weight: 800; color: var(--color-text); line-height: 1.15;
  margin-bottom: var(--space-3);
}

.reviews-heading-accent {
  display: flex; align-items: center; justify-content: center;
  gap: 12px; margin-bottom: var(--space-5);
}
.accent-line {
  width: 72px; height: 3px; border-radius: 2px;
  background: linear-gradient(90deg, var(--color-primary), var(--color-primary-light));
}
.accent-icon { color: var(--color-primary); opacity: 0.6; }

/* Aggregate badge */
.reviews-aggregate {
  display: inline-flex; align-items: center; gap: 14px;
  background: var(--color-surface); border: 1px solid var(--color-border);
  border-radius: var(--radius-2xl); padding: 12px 24px;
  box-shadow: var(--shadow-sm);
}
.aggregate-google-icon { width: 32px; height: 32px; flex-shrink: 0; }
.aggregate-info { display: flex; flex-direction: column; align-items: flex-start; gap: 2px; }
.aggregate-top-row { display: flex; align-items: center; gap: 8px; }
.aggregate-rating {
  font-family: var(--font-heading); font-size: 1.6rem; font-weight: 800;
  color: var(--color-text); line-height: 1;
}
.aggregate-stars { display: flex; gap: 2px; }
.aggregate-meta { font-size: var(--text-xs); color: var(--color-text-muted); font-weight: 500; }
.aggregate-meta strong { color: var(--color-text); font-weight: 700; }

/* Carousel wrapper */
.reviews-carousel-wrapper { position: relative; }

.reviews-track {
  display: flex; gap: 24px; overflow-x: auto; overflow-y: hidden;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none; -ms-overflow-style: none;
}
.reviews-track::-webkit-scrollbar { display: none; }

/* Arrows */
.carousel-btn {
  position: absolute; top: 50%; transform: translateY(-50%);
  z-index: 10; width: 48px; height: 48px; border-radius: 50%;
  background: var(--color-bg); border: 1px solid var(--color-border);
  box-shadow: var(--shadow-md);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: all var(--transition-base);
}
.carousel-btn:hover {
  background: var(--color-primary); border-color: var(--color-primary);
  box-shadow: var(--shadow-lg); transform: translateY(-50%) scale(1.05);
}
.carousel-btn:hover svg { stroke: #fff; }
.carousel-btn svg {
  width: 20px; height: 20px; stroke: var(--color-text);
  fill: none; stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;
  transition: stroke var(--transition-fast);
}
.carousel-btn.prev { left: -24px; }
.carousel-btn.next { right: -24px; }
.carousel-btn.disabled { opacity: 0.3; cursor: default; pointer-events: none; }

/* Dot indicators */
.carousel-dots {
  display: flex; justify-content: center;
  gap: 8px; margin-top: var(--space-6);
}
.carousel-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--color-border); border: none; padding: 0;
  cursor: pointer; transition: all var(--transition-base);
}
.carousel-dot.active {
  background: var(--color-primary); width: 24px; border-radius: 4px;
}

/* Review card */
.review-card {
  flex: 0 0 calc((100% - 48px) / 3);
  scroll-snap-align: start;
  background: var(--color-bg); border: 1px solid var(--color-border);
  border-radius: var(--radius-xl); padding: var(--space-5);
  display: flex; flex-direction: column; gap: var(--space-4);
  transition: box-shadow var(--transition-base), transform var(--transition-base), border-color var(--transition-base);
  cursor: default; min-height: 260px;
}
.review-card:hover {
  box-shadow: var(--shadow-lg); transform: translateY(-4px);
  border-color: rgba(66,133,244,0.2);
}

.review-card-header { display: flex; align-items: flex-start; gap: 12px; }

.reviewer-avatar {
  width: 44px; height: 44px; border-radius: 50%;
  background: #4285F4; color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-heading); font-weight: 700; font-size: 1rem;
  flex-shrink: 0; text-transform: uppercase;
}

.reviewer-info { flex: 1; min-width: 0; }
.reviewer-name {
  font-family: var(--font-body); font-size: var(--text-sm);
  font-weight: 600; color: var(--color-text); line-height: 1.3;
}
.reviewer-meta { display: flex; align-items: center; gap: 6px; margin-top: 2px; }
.review-date { font-size: 0.7rem; color: var(--color-text-muted); }

.review-source-icon { width: 18px; height: 18px; flex-shrink: 0; margin-left: auto; }

.review-stars { display: flex; gap: 2px; }

.review-text-wrapper {
  flex: 1; display: flex; flex-direction: column; align-items: flex-start;
}
.review-text {
  font-size: var(--text-sm); color: #3c4043;
  line-height: 1.65; margin: 0; font-style: italic;
  display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;
  transition: all var(--transition-base);
}
.review-text.expanded {
  display: block; -webkit-line-clamp: unset; overflow: visible;
}
.read-more-btn {
  background: none; border: none; font-family: var(--font-body); 
  font-size: 0.8rem; font-weight: 700; color: var(--color-primary);
  margin-top: 8px; padding: 0; cursor: pointer; text-decoration: underline;
}
.read-more-btn:hover { color: var(--color-primary-dark); }

.review-photo-wrapper {
  margin-top: 12px; border-radius: 8px; overflow: hidden;
  height: 110px; width: 100%; border: 1px solid var(--color-border);
  flex-shrink: 0;
}
.review-job-photo {
  width: 100%; height: 100%; object-fit: cover;
  transition: transform var(--transition-base);
}
.review-card:hover .review-job-photo { transform: scale(1.05); }

/* Responsive */
@media (max-width: 1024px) { .review-card { flex: 0 0 calc((100% - 24px) / 2); } }
@media (max-width: 640px) {
  .review-card { flex: 0 0 calc(100% - 16px); }
  .reviews-heading { font-size: var(--text-3xl); }
  .carousel-btn.prev { left: -6px; }
  .carousel-btn.next { right: -6px; }
}
</style>

<script>
  const track    = document.getElementById('reviewsTrack') as HTMLElement;
  const prevBtn  = document.getElementById('prevBtn') as HTMLButtonElement;
  const nextBtn  = document.getElementById('nextBtn') as HTMLButtonElement;
  const dotsEl   = document.getElementById('carouselDots') as HTMLElement;

  const cards    = track?.querySelectorAll('.review-card');
  const visibleCount = () => window.innerWidth > 1024 ? 3 : window.innerWidth > 640 ? 2 : 1;
  let page = 0;

  function totalPages() {
    return Math.ceil((cards?.length ?? 0) / visibleCount());
  }

  // Build dots
  function buildDots() {
    dotsEl.innerHTML = '';
    for (let i = 0; i < totalPages(); i++) {
      // Changed from <button> to <span> to prevent mobile browsers from
      // auto-focusing newly injected interactive elements on load.
      const d = document.createElement('span');
      d.className = 'carousel-dot' + (i === 0 ? ' active' : '');
      d.setAttribute('aria-label', `Go to page ${i + 1}`);
      d.setAttribute('role', 'button');
      d.setAttribute('tabindex', '0');
      d.addEventListener('click', () => doScroll(i));
      dotsEl.appendChild(d);
    }
  }

  function goTo(p: number) {
    // Only update state and UI. CSS scroll-snap will handle actual alignment 
    // when user interacts, avoiding iOS Safari forced vertical jumps on programmatic scroll.
    page = Math.max(0, Math.min(p, totalPages() - 1));
    updateUI();
  }

  function updateUI() {
    if (prevBtn) prevBtn.classList.toggle('disabled', page === 0);
    if (nextBtn) nextBtn.classList.toggle('disabled', page >= totalPages() - 1);
    dotsEl.querySelectorAll('.carousel-dot').forEach((d, i) =>
      d.classList.toggle('active', i === page)
    );
  }

  // Handle manual programmatic scrolling without smooth behavior if requested
  function doScroll(p: number) {
    page = Math.max(0, Math.min(p, totalPages() - 1));
    const card = cards?.[page * visibleCount()] as HTMLElement;
    if (track && card) {
       // Disable smooth scrolling on mobile dynamically to avoid Safari bug
       track.style.scrollBehavior = 'auto';
       track.scrollLeft = card.offsetLeft - track.offsetLeft;
       track.style.scrollBehavior = 'smooth';
    }
    updateUI();
  }

  prevBtn?.addEventListener('click', () => doScroll(page - 1));
  nextBtn?.addEventListener('click', () => doScroll(page + 1));

  // Read More expander logic
  document.querySelectorAll('.read-more-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const targetBtn = e.target as HTMLButtonElement;
      const textNode = targetBtn.previousElementSibling as HTMLElement;
      if (textNode && textNode.classList.contains('expanded')) {
        textNode.classList.remove('expanded');
        targetBtn.textContent = 'Read more';
        targetBtn.setAttribute('aria-expanded', 'false');
      } else if (textNode) {
        textNode.classList.add('expanded');
        targetBtn.textContent = 'Read less';
        targetBtn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  buildDots();
  updateUI();
</script>
