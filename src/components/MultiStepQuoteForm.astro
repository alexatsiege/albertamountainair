---
interface Props {
  headline?: string;
  subheadline?: string;
  logoSrc?: string;
}

const { 
  headline = "Get Your Custom AC Quote", 
  subheadline = "Answer a few questions to get a personalized estimate instantly.",
  logoSrc
} = Astro.props;
---

<section class="quote-hero">
  <!-- Dynamic Background from hero template vibe -->
  <div class="bg-layer">
    <div class="glass-overlay"></div>
  </div>

  <div class="container hero-container">
    <div class="typeform-header">
      <div class="stamp-wrapper">
        <span class="hero-stamp">FAST & FREE</span>
      </div>
      <h1 class="hero-title" set:html={headline.replace('|', '<br/>')}></h1>
      <p class="hero-desc">{subheadline}</p>
    </div>

    <div class="hero-form-wrapper">
      <div class="quote-card">
        {logoSrc && (
          <div class="watermark" aria-hidden="true">
            <img src={logoSrc} alt="Your Company Watermark" />
          </div>
        )}

        <div class="form-brand-header">
          <span class="brand-eyebrow">Official Estimate Tool</span>
          <h2 class="brand-headline">Estimate Builder</h2>
        </div>

        <!-- Progress Bar -->
        <div class="progress-container">
          <div class="progress-bar" id="quote-progress" style="width: 25%;"></div>
        </div>

        <form id="ac-quote-form" class="quote-form">
          <!-- Step 1: House Size -->
          <div class="form-step active" id="step-1">
            <h3>How large is your home?</h3>
            <p class="step-desc">This helps us calculate the exact tonnage required.</p>
            <div class="radio-grid">
              <label class="radio-card">
                <input type="radio" name="house_size" value="Under 1,500 sq ft" data-key="a" required>
                <div class="card-content"><span class="key-hint">A</span> Under 1,500 sq ft</div>
              </label>
              <label class="radio-card">
                <input type="radio" name="house_size" value="1,500 - 2,500 sq ft" data-key="b">
                <div class="card-content"><span class="key-hint">B</span> 1,500 - 2,500 sq ft</div>
              </label>
              <label class="radio-card">
                <input type="radio" name="house_size" value="2,500 - 3,500 sq ft" data-key="c">
                <div class="card-content"><span class="key-hint">C</span> 2,500 - 3,500 sq ft</div>
              </label>
              <label class="radio-card">
                <input type="radio" name="house_size" value="Over 3,500 sq ft" data-key="d">
                <div class="card-content"><span class="key-hint">D</span> Over 3,500 sq ft</div>
              </label>
            </div>
            <div class="keyboard-instructions">Press A, B, C, or D to select</div>
          </div>

          <!-- Step 2: Home Age -->
          <div class="form-step" id="step-2">
            <h3>When was your home built?</h3>
            <p class="step-desc">Ductwork age affects system efficiency.</p>
            <div class="radio-grid">
              <label class="radio-card">
                <input type="radio" name="home_age" value="Under 10 Years" data-key="a" required>
                <div class="card-content"><span class="key-hint">A</span> Under 10 Years</div>
              </label>
              <label class="radio-card">
                <input type="radio" name="home_age" value="10 - 20 Years" data-key="b">
                <div class="card-content"><span class="key-hint">B</span> 10 - 20 Years</div>
              </label>
              <label class="radio-card">
                <input type="radio" name="home_age" value="Over 20 Years" data-key="c">
                <div class="card-content"><span class="key-hint">C</span> Over 20 Years</div>
              </label>
            </div>
            <div class="keyboard-instructions">Press A, B, or C to select</div>
          </div>

          <!-- Step 3: Add-ons -->
          <div class="form-step" id="step-3">
            <h3>Any air quality concerns?</h3>
            <p class="step-desc">Select premium features (Optional). Press ENTER to continue.</p>
            <div class="checkbox-grid">
              <label class="checkbox-card">
                <input type="checkbox" name="addons" value="UV Light Scrubber" data-key="a">
                <div class="card-content">
                  <span class="key-hint">A</span>
                  <span>UV Light Scrubber</span>
                </div>
              </label>
              <label class="checkbox-card">
                <input type="checkbox" name="addons" value="HEPA Media Filter" data-key="b">
                <div class="card-content">
                  <span class="key-hint">B</span>
                  <span>HEPA Media Filter</span>
                </div>
              </label>
              <label class="checkbox-card">
                <input type="checkbox" name="addons" value="Smart Thermostat" data-key="c">
                <div class="card-content">
                  <span class="key-hint">C</span>
                  <span>Smart Thermostat</span>
                </div>
              </label>
            </div>
            <button type="button" class="btn btn-primary step-next-btn" style="width: 100%; margin-top: 1rem; font-size: 1.25rem; padding: 1.25rem;">Continue <span class="enter-hint">Press Enter ↵</span></button>
          </div>

          <!-- Step 4: Contact -->
          <div class="form-step" id="step-4">
            <h3>Where should we send your quote?</h3>
            <p class="step-desc">We will calculate your results and email them instantly.</p>
            <div class="input-group">
              <input type="text" name="full_name" placeholder="First & Last Name" required>
            </div>
            <div class="input-group">
              <input type="tel" name="phone" placeholder="Phone Number" required>
            </div>
            <div class="input-group">
              <input type="email" name="email" placeholder="Email Address" required>
            </div>
            <button type="submit" class="btn btn-primary" id="submit-quote">Get My Free Quote</button>
          </div>

          <!-- Success Step: Pricing Tiers -->
          <div class="form-step success-step" id="step-success">
            <div class="success-header">
              <h3>Your System Estimates</h3>
              <p>Based on your home's profile, here are three custom replacement options.</p>
            </div>
            
            <div class="pricing-tiers">
              <!-- Good Tier -->
              <div class="tier-card good-tier">
                <div class="tier-header">Good</div>
                <div class="tier-body">
                  <h4>Split System Replacement</h4>
                  <p class="specs">14 SEER • Single Stage • Complete Install</p>
                  <div class="img-wrapper"><img src="/_assets/HERO-BG.webp" alt="Basic System" class="system-img" /></div>
                  <div class="price-block">
                    <span class="est-label">Estimated price</span>
                    <div class="price-range"><span class="price-val">$5,800</span> - <span class="price-val">$6,500</span></div>
                    <span class="monthly">As low as $75/mo</span>
                  </div>
                  <div class="efficiency-box">
                    <strong>Standard Efficiency</strong>
                    <p>Basic cooling that meets modern minimum requirements. Lowest upfront cost.</p>
                  </div>
                  <button type="button" class="btn btn-primary" style="width:100%">Book Consultation</button>
                </div>
              </div>

              <!-- Better Tier -->
              <div class="tier-card better-tier">
                <div class="tier-header">Better</div>
                <div class="tier-body">
                  <h4>High Efficiency System</h4>
                  <p class="specs">16 SEER • Two Stage • Complete Install</p>
                  <div class="img-wrapper"><img src="/_assets/HERO-BG.webp" alt="Better System" class="system-img" /></div>
                  <div class="price-block">
                    <span class="est-label">Estimated price</span>
                    <div class="price-range"><span class="price-val">$7,200</span> - <span class="price-val">$8,500</span></div>
                    <span class="monthly">As low as $95/mo</span>
                  </div>
                  <div class="efficiency-box">
                    <strong>High Efficiency</strong>
                    <p>Balanced efficiency with moderate energy savings. Good compromise between upfront and long-term cost.</p>
                  </div>
                  <button type="button" class="btn btn-primary" style="width:100%">Book Consultation</button>
                </div>
              </div>

              <!-- Best Tier -->
              <div class="tier-card best-tier">
                <div class="tier-header">Best</div>
                <div class="tier-body">
                  <h4>Premium Variable Capacity</h4>
                  <p class="specs">18+ SEER • Variable Speed • Ultimate Comfort</p>
                  <div class="img-wrapper"><img src="/_assets/HERO-BG.webp" alt="Best System" class="system-img" /></div>
                  <div class="price-block">
                    <span class="est-label">Estimated price</span>
                    <div class="price-range"><span class="price-val">$9,500</span> - <span class="price-val">$11,500</span></div>
                    <span class="monthly">As low as $125/mo</span>
                  </div>
                  <div class="efficiency-box">
                    <strong>Maximum Efficiency</strong>
                    <p>Ultimate comfort with pinpoint humidity control and the lowest possible utility bills.</p>
                  </div>
                  <button type="button" class="btn btn-primary" style="width:100%">Book Consultation</button>
                </div>
              </div>
            </div>
          </div>

        </form>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('ac-quote-form') as HTMLFormElement;
    if (!form) return;

    const steps = document.querySelectorAll('.form-step');
    const progressBar = document.getElementById('quote-progress');
    let currentStep = 0;

    // Handle Radio auto-advance for steps 1 and 2
    const radioInputs = form.querySelectorAll('input[type="radio"]');
    radioInputs.forEach(input => {
      input.addEventListener('change', () => {
        // Find which step this is in
        const parentStep = (input as HTMLElement).closest('.form-step');
        if (parentStep && parentStep.id !== 'step-4') {
          setTimeout(() => advanceStep(), 250); // slight delay for visual feedback
        }
      });
    });

    // Handle manual next button (Step 3)
    const nextBtns = form.querySelectorAll('.step-next-btn');
    nextBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        advanceStep();
      });
    });

    // Handle Keyboard Navigation (Typeform style)
    document.addEventListener('keydown', (e) => {
      // Ignore if user is typing in a text input (Step 4)
      if (document.activeElement?.tagName === 'INPUT' && document.activeElement?.getAttribute('type') !== 'radio' && document.activeElement?.getAttribute('type') !== 'checkbox') return;
      
      const activeStep = steps[currentStep];
      if (!activeStep || activeStep.id === 'step-success' || activeStep.id === 'step-4') return;

      const key = e.key.toLowerCase();
      
      // Handle Enter for Continue button
      if (key === 'enter') {
        e.preventDefault();
        const nextBtn = activeStep.querySelector('.step-next-btn') as HTMLButtonElement;
        if (nextBtn) {
          nextBtn.click();
        }
        return;
      }

      // Handle A, B, C, D
      const targetInput = activeStep.querySelector(`input[data-key="${key}"]`) as HTMLInputElement;
      if (targetInput) {
        targetInput.click(); // This will natively trigger the change event and visual selection
      }
    });

    function advanceStep() {
      if (currentStep < steps.length - 2) { // -2 because last is success
        steps[currentStep].classList.remove('active');
        currentStep++;
        steps[currentStep].classList.add('active');
        updateProgress();
      }
    }

    function updateProgress() {
      // 4 steps total (0 to 3) before success
      const percentage = ((currentStep + 1) / 4) * 100;
      if (progressBar) {
        progressBar.style.width = `${percentage}%`;
      }
    }

    // Handle Form Submit
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const submitBtn = document.getElementById('submit-quote') as HTMLButtonElement;
      submitBtn.innerHTML = 'Calculating...';
      submitBtn.disabled = true;

      // Collect data
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      const addons = formData.getAll('addons');
      data.addons = addons.join(', ');

      console.log('Quote Request Submitted:', data);

      // Simulate API delay
      setTimeout(() => {
        steps[currentStep].classList.remove('active');
        currentStep++; // Move to success step
        steps[currentStep].classList.add('active');
        
        // Hide progress bar on success
        const progCont = document.querySelector('.progress-container') as HTMLElement;
        if(progCont) progCont.style.display = 'none';

        // Hide form brand header
        const brandHeader = document.querySelector('.form-brand-header') as HTMLElement;
        if(brandHeader) brandHeader.style.display = 'none';

        // Expand container to full width natively
        const heroContainer = document.querySelector('.hero-container') as HTMLElement;
        if(heroContainer) heroContainer.classList.add('success-mode');

        const typeformHeader = document.querySelector('.typeform-header') as HTMLElement;
        if(typeformHeader) typeformHeader.style.display = 'none';

      }, 1200);
    });
  });
</script>

<style>
  .quote-hero {
    position: relative;
    padding: calc(var(--header-height) + var(--space-xl)) 0 var(--space-2xl);
    min-height: 90vh;
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 100%);
    overflow: hidden;
  }

  .bg-layer {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image: url('/_assets/HERO-BG.webp');
    background-size: cover;
    background-position: center;
    z-index: 1;
  }

  .glass-overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(135deg, rgba(20, 60, 100, 0.92) 0%, rgba(41, 176, 229, 0.85) 100%);
    backdrop-filter: blur(8px);
  }

  .hero-container {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr;
    max-width: 800px;
    margin: 0 auto;
    gap: var(--space-xl);
    align-items: center;
    transition: all 0.5s ease;
  }

  .hero-container.success-mode {
    max-width: 1200px;
  }

  /* Typography */
  .typeform-header {
    color: white;
    text-align: center;
    max-width: 650px;
    margin: 0 auto;
  }
  .hero-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: var(--space-md);
  }
  .hero-desc {
    font-size: 1.15rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: var(--space-lg);
    max-width: 500px;
  }

  .stamp-wrapper { margin-bottom: var(--space-md); }
  .hero-stamp {
    background-color: var(--color-accent);
    color: white;
    font-size: 0.8rem;
    font-weight: 800;
    padding: 0.4rem 1rem;
    border-radius: 100px;
    letter-spacing: 0.05em;
  }

  .trust-indicators {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }
  .trust-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 0.95rem;
    background: rgba(0,0,0,0.2);
    padding: 0.5rem 1rem;
    border-radius: 8px;
    backdrop-filter: blur(4px);
  }

  /* Form UI */
  .quote-card {
    background: white;
    border-radius: 20px;
    padding: var(--space-xl);
    box-shadow: 0 30px 60px -15px rgba(0,0,0,0.5);
    position: relative;
    overflow: hidden;
    z-index: 2;
  }

  @media (min-width: 768px) {
    .quote-card {
      padding: calc(var(--space-2xl) * 1.1);
    }
  }

  .watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80%;
    opacity: 0.04;
    pointer-events: none;
    z-index: -1;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .watermark img {
    width: 100%;
    max-width: 400px;
    height: auto;
    filter: grayscale(100%);
  }

  .form-brand-header {
    text-align: center;
    margin-bottom: var(--space-lg);
  }
  .brand-eyebrow {
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: 0.25rem;
  }
  .brand-headline {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-primary-dark);
    margin: 0;
  }

  .progress-container {
    background: #E2E8F0;
    height: 6px;
    border-radius: 6px;
    margin-bottom: var(--space-xl);
    overflow: hidden;
  }
  .progress-bar {
    height: 100%;
    background: var(--color-accent);
    transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .form-step {
    display: none;
    animation: fadeInUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .form-step.active {
    display: block;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .form-step h3 {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--color-primary-dark);
    margin-bottom: 0.25rem;
    text-align: center;
  }
  .step-desc {
    color: #64748B;
    margin-bottom: var(--space-xl);
    font-size: 1rem;
    text-align: center;
  }

  /* Selection Cards */
  .radio-grid, .checkbox-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 500px) {
    .radio-grid { grid-template-columns: 1fr 1fr; }
  }

  .radio-card input, .checkbox-card input {
    display: none;
  }
  
  .card-content {
    border: 2px solid #E2E8F0;
    border-radius: 12px;
    padding: 1.25rem 1rem;
    text-align: center;
    font-weight: 700;
    color: var(--color-primary-dark);
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: rgba(248, 250, 252, 0.7);
    backdrop-filter: blur(4px);
  }

  .radio-card:hover .card-content, .checkbox-card:hover .card-content {
    border-color: #CBD5E1;
    background: white;
  }

  .radio-card input:checked + .card-content, 
  .checkbox-card input:checked + .card-content {
    border-color: var(--color-primary);
    background: rgba(41, 176, 229, 0.05);
    box-shadow: 0 4px 12px rgba(41, 176, 229, 0.15);
  }

  .radio-card input:checked + .card-content .key-hint, 
  .checkbox-card input:checked + .card-content .key-hint {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  /* Keyboard Hints */
  .key-hint {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background: white;
    color: #64748B;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 800;
    margin-right: 0.5rem;
    border: 1px solid #CBD5E1;
    transition: all 0.2s ease;
  }
  
  .keyboard-instructions {
    font-size: 0.85rem;
    color: #94A3B8;
    margin-top: 1.25rem;
    text-align: center;
    letter-spacing: 0.02em;
  }

  .enter-hint {
    font-size: 0.85rem;
    opacity: 0.7;
    font-weight: normal;
    margin-left: 0.5rem;
  }

  /* Standard Inputs */
  .input-group {
    margin-bottom: 1rem;
  }
  .input-group input {
    width: 100%;
    padding: 1.25rem;
    border: 2px solid #E2E8F0;
    border-radius: 8px;
    font-family: inherit;
    font-size: 1.1rem;
    transition: border-color 0.2s ease;
  }
  .input-group input:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  /* Success Step & Pricing Tiers */
  .success-header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }
  .success-header p {
    color: #64748B;
    font-size: 1.1rem;
  }

  .pricing-tiers {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .pricing-tiers {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }

  .tier-card {
    border-radius: 12px;
    overflow: hidden;
    background: white;
    border: 1px solid #E2E8F0;
    box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05);
    display: flex;
    flex-direction: column;
    text-align: center;
  }

  .tier-header {
    padding: 1rem;
    font-size: 1.25rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .good-tier .tier-header { background: #10B981; color: white; }
  .better-tier .tier-header { background: #F59E0B; color: white; }
  .best-tier .tier-header { background: #3B82F6; color: white; }

  .tier-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .tier-body h4 {
    font-size: 1.25rem;
    color: var(--color-primary-dark);
    margin-bottom: 0.25rem;
    font-weight: 800;
  }
  .specs {
    font-size: 0.85rem;
    color: #64748B;
    margin-bottom: 1.5rem;
  }

  .img-wrapper {
    margin-bottom: 1.5rem;
    height: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .system-img {
    max-height: 100%;
    object-fit: contain;
    border-radius: 8px;
  }

  .price-block {
    margin-bottom: 1.5rem;
  }
  .est-label {
    display: block;
    font-size: 0.85rem;
    color: #64748B;
    margin-bottom: 0.25rem;
  }
  .price-range {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }
  .price-val {
    font-size: 1.75rem;
  }
  .monthly {
    font-size: 0.9rem;
    color: #64748B;
  }

  .efficiency-box {
    background: #F8FAFC;
    border-radius: 8px;
    padding: 1rem;
    margin-bottom: 1.5rem;
    text-align: left;
    font-size: 0.85rem;
    border: 1px solid #E2E8F0;
    flex: 1;
  }
  .efficiency-box strong {
    display: block;
    color: var(--color-primary-dark);
    margin-bottom: 0.25rem;
    font-size: 0.95rem;
  }
  .efficiency-box p {
    color: #64748B;
    margin: 0;
    line-height: 1.4;
  }

</style>
