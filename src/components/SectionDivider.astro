---
// SectionDivider.astro — Between-section animated transitions
// Variants: 'wave' | 'truck' | 'cityscape' | 'stripe' | 'airflow'
// OWA Brand: flag-ribbon replaced with 'airflow' — animated sweep of arrow chevrons

interface Props {
  variant?: 'wave' | 'truck' | 'cityscape' | 'stripe' | 'airflow';
  truckSrc?: string;
  clientName?: string;
  townName?: string;
  flip?: boolean;
}

const {
  variant = 'wave',
  truckSrc = '/_assets/OWA Vans.webp',
  clientName = "Your Company",
  townName = "your area",
  flip = false,
} = Astro.props;
---

{variant === 'stripe' && (
  <div class="div-stripe" aria-hidden="true"></div>
)}

{variant === 'wave' && (
  <div class={`div-wave ${flip ? 'div-wave--flip' : ''}`} aria-hidden="true">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path class="wave-1" d="M0,40 C360,80 720,0 1080,40 C1260,60 1350,50 1440,40 L1440,80 L0,80 Z"/>
      <path class="wave-2" d="M0,55 C240,20 480,70 720,55 C960,40 1200,65 1440,55 L1440,80 L0,80 Z"/>
    </svg>
  </div>
)}

{variant === 'truck' && (
  <div class="div-truck" aria-hidden="true" id="divTruckWrap">
    <div class="div-truck__road">
      <div class="div-truck__dashes"></div>
    </div>
    <div class="div-truck__track">
      <img
        src={truckSrc}
        alt={`${clientName} truck heading to HVAC service in ${townName}`}
        class="div-truck__img"
        id="divTruckImg"
      />
    </div>
  </div>
)}

{variant === 'cityscape' && (
  <div class="div-city" aria-hidden="true">
    <div class="div-city__glow"></div>
    <svg viewBox="0 0 1440 140" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <rect x="0"    y="90"  width="60"  height="50" fill="#0d1b2a" opacity="0.6"/>
      <rect x="20"   y="70"  width="30"  height="70" fill="#0d1b2a" opacity="0.5"/>
      <rect x="70"   y="80"  width="50"  height="60" fill="#0d1b2a" opacity="0.6"/>
      <rect x="130"  y="60"  width="40"  height="80" fill="#0d1b2a" opacity="0.5"/>
      <rect x="185"  y="75"  width="55"  height="65" fill="#0d1b2a" opacity="0.6"/>
      <rect x="250"  y="50"  width="35"  height="90" fill="#0d1b2a" opacity="0.5"/>
      <rect x="295"  y="68"  width="50"  height="72" fill="#0d1b2a" opacity="0.6"/>
      <rect x="360"  y="58"  width="40"  height="82" fill="#0d1b2a" opacity="0.5"/>
      <rect x="415"  y="72"  width="55"  height="68" fill="#0d1b2a" opacity="0.6"/>
      <rect x="480"  y="45"  width="45"  height="95" fill="#0d1b2a" opacity="0.5"/>
      <rect x="535"  y="65"  width="60"  height="75" fill="#0d1b2a" opacity="0.6"/>
      <rect x="605"  y="55"  width="35"  height="85" fill="#0d1b2a" opacity="0.5"/>
      <rect x="650"  y="70"  width="50"  height="70" fill="#0d1b2a" opacity="0.6"/>
      <rect x="710"  y="48"  width="40"  height="92" fill="#0d1b2a" opacity="0.5"/>
      <rect x="760"  y="62"  width="55"  height="78" fill="#0d1b2a" opacity="0.6"/>
      <rect x="825"  y="52"  width="45"  height="88" fill="#0d1b2a" opacity="0.5"/>
      <rect x="880"  y="68"  width="35"  height="72" fill="#0d1b2a" opacity="0.6"/>
      <rect x="925"  y="58"  width="60"  height="82" fill="#0d1b2a" opacity="0.5"/>
      <rect x="995"  y="72"  width="40"  height="68" fill="#0d1b2a" opacity="0.6"/>
      <rect x="1045" y="50"  width="50"  height="90" fill="#0d1b2a" opacity="0.5"/>
      <rect x="1105" y="65"  width="35"  height="75" fill="#0d1b2a" opacity="0.6"/>
      <rect x="1150" y="55"  width="55"  height="85" fill="#0d1b2a" opacity="0.5"/>
      <rect x="1215" y="70"  width="45"  height="70" fill="#0d1b2a" opacity="0.6"/>
      <rect x="1270" y="48"  width="60"  height="92" fill="#0d1b2a" opacity="0.5"/>
      <rect x="1340" y="62"  width="40"  height="78" fill="#0d1b2a" opacity="0.6"/>
      <rect x="1390" y="72"  width="50"  height="68" fill="#0d1b2a" opacity="0.5"/>
      <rect x="0" y="130" width="1440" height="20" fill="#1a1a2e"/>
      <!-- Window lights -->
      <rect class="city-win" x="25"   y="78"  width="6" height="5"  fill="#F59E0B" opacity="0.7"/>
      <rect class="city-win" x="135"  y="68"  width="5" height="4"  fill="#F59E0B" opacity="0.6"/>
      <rect class="city-win" x="255"  y="58"  width="6" height="5"  fill="#F59E0B" opacity="0.8"/>
      <rect class="city-win" x="365"  y="65"  width="5" height="4"  fill="#F59E0B" opacity="0.5"/>
      <rect class="city-win" x="485"  y="52"  width="6" height="5"  fill="#F59E0B" opacity="0.7"/>
      <rect class="city-win" x="610"  y="62"  width="5" height="4"  fill="#F59E0B" opacity="0.6"/>
      <rect class="city-win" x="715"  y="55"  width="6" height="5"  fill="#F59E0B" opacity="0.8"/>
      <rect class="city-win" x="830"  y="60"  width="5" height="4"  fill="#F59E0B" opacity="0.5"/>
      <rect class="city-win" x="930"  y="65"  width="6" height="5"  fill="#F59E0B" opacity="0.7"/>
      <rect class="city-win" x="1050" y="57"  width="5" height="4"  fill="#F59E0B" opacity="0.6"/>
      <rect class="city-win" x="1155" y="62"  width="6" height="5"  fill="#F59E0B" opacity="0.8"/>
      <rect class="city-win" x="1275" y="55"  width="5" height="4"  fill="#F59E0B" opacity="0.5"/>
    </svg>
    <img src={truckSrc} alt={`${clientName} HVAC truck completing service in ${townName}`} class="div-city__truck" />
  </div>
)}

{variant === 'airflow' && (
  <div class="div-airflow" aria-hidden="true">
    <svg class="airflow-svg" viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Flowing base wave -->
      <path class="af-wave-1" d="M0,40 C360,10 720,70 1080,40 C1260,25 1350,35 1440,30 L1440,80 L0,80 Z"/>
      <path class="af-wave-2" d="M0,60 C240,30 480,75 720,55 C960,35 1200,65 1440,50 L1440,80 L0,80 Z"/>
    </svg>
    <!-- Staggered arrow chevrons flowing right -->
    <div class="airflow-arrows">
      {Array.from({ length: 9 }).map((_, i) => (
        <svg class={`af-arrow af-arrow-${i+1}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      ))}
    </div>
  </div>
)}

<style>
/* ─── Stripe ───────────────────────────────────────────── */
.div-stripe {
  height: 6px;
  background: linear-gradient(90deg,
    var(--color-primary) 0%,
    var(--color-accent)  25%,
    var(--color-primary) 50%,
    var(--color-accent)  75%,
    var(--color-primary) 100%);
  background-size: 300% 100%;
  animation: stripe-slide 3s linear infinite;
  box-shadow: 0 0 20px color-mix(in srgb, var(--color-accent) 30%, transparent),
              0 0 60px color-mix(in srgb, var(--color-primary) 15%, transparent);
}
@keyframes stripe-slide {
  0%   { background-position: 0% 0; }
  100% { background-position: 300% 0; }
}

/* ─── Wave ─────────────────────────────────────────────── */
.div-wave {
  position: relative; height: 80px; overflow: hidden;
  background: transparent;
}
.div-wave svg { position: absolute; bottom: 0; left: 0; width: 100%; height: 100%; }
.wave-1 {
  fill: color-mix(in srgb, var(--color-primary) 12%, transparent);
  animation: wave-drift 8s ease-in-out infinite;
}
.wave-2 {
  fill: color-mix(in srgb, var(--color-accent) 18%, transparent);
  animation: wave-drift 6s ease-in-out infinite reverse;
}
.div-wave--flip .wave-1 { fill: color-mix(in srgb, var(--color-primary) 10%, rgba(255,255,255,0.06)); }
.div-wave--flip .wave-2 { fill: color-mix(in srgb, var(--color-accent) 15%, rgba(255,255,255,0.08)); }
@keyframes wave-drift {
  0%, 100% { transform: scaleX(1); }
  50%       { transform: scaleX(1.05) translateX(-2%); }
}

/* ─── Truck Highway ────────────────────────────────────── */
.div-truck { position: relative; height: 100px; overflow: hidden; background: #fff; }
.div-truck__road { position: absolute; bottom: 0; left: 0; right: 0; height: 60px; background: #1a1a2e; }
.div-truck__road::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: linear-gradient(90deg, var(--color-primary), var(--color-accent), var(--color-primary));
  background-size: 200% 100%; animation: stripe-slide 3s linear infinite;
}
.div-truck__dashes {
  position: absolute; top: 50%; left: 0; width: 200%; height: 3px; transform: translateY(-50%);
  background: repeating-linear-gradient(90deg,
    rgba(255,255,255,0.3) 0px, rgba(255,255,255,0.3) 30px,
    transparent 30px, transparent 60px);
  animation: road-scroll 2s linear infinite;
}
@keyframes road-scroll {
  0%   { transform: translateY(-50%) translateX(0); }
  100% { transform: translateY(-50%) translateX(-60px); }
}
.div-truck__track {
  position: absolute; bottom: 20px; left: 0; width: 100%; overflow: hidden; height: 65px;
}
.div-truck__img {
  position: absolute; bottom: 0; left: -120px;
  height: 65px; width: auto;
  filter: drop-shadow(0 4px 12px rgba(0,0,0,0.4));
  animation: truck-bounce 1.5s ease-in-out infinite;
  will-change: transform;
  transform: scaleX(-1);
}
@keyframes truck-bounce {
  0%, 100% { transform: translateY(0) scaleX(-1); }
  50%       { transform: translateY(-3px) scaleX(-1); }
}

/* ─── Cityscape ────────────────────────────────────────── */
.div-city {
  position: relative; height: 140px; overflow: hidden;
  background: linear-gradient(180deg, #fff 0%, #1a1a2e 70%);
}
.div-city__glow {
  position: absolute; bottom: 0; width: 100%; height: 60%;
  background: linear-gradient(180deg, transparent, rgba(41,176,229,0.05));
}
.div-city svg { position: absolute; bottom: 0; left: 0; width: 100%; height: 100%; }
.city-win { animation: win-flicker 3s ease-in-out infinite; }
.city-win:nth-child(odd) { animation-delay: -1.5s; }
@keyframes win-flicker {
  0%, 100% { opacity: 0.8; }
  50%       { opacity: 0.2; }
}
.div-city__truck {
  position: absolute; bottom: 2px; left: -80px;
  height: 26px; width: auto;
  filter: drop-shadow(0 2px 8px rgba(0,0,0,0.6));
  animation: city-drive 12s linear infinite;
  transform: scaleX(-1);
}
@keyframes city-drive {
  0%   { left: -80px; }
  100% { left: 110%; }
}

/* ─── OWA Airflow Divider (replaces flag-ribbon) ────────── */
.div-airflow {
  position: relative;
  height: 80px;
  overflow: hidden;
  background: transparent;
}
.airflow-svg {
  position: absolute; bottom: 0; left: 0; width: 100%; height: 100%;
}
.af-wave-1 {
  fill: color-mix(in srgb, var(--color-primary) 14%, transparent);
  animation: wave-drift 9s ease-in-out infinite;
}
.af-wave-2 {
  fill: color-mix(in srgb, var(--color-primary-dark) 20%, transparent);
  animation: wave-drift 7s ease-in-out infinite reverse;
}

/* Flowing arrow chevrons */
.airflow-arrows {
  position: absolute;
  top: 50%; transform: translateY(-50%);
  left: 0; right: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  pointer-events: none;
}
.af-arrow {
  width: 28px; height: 28px;
  color: var(--color-primary);
  opacity: 0;
  animation: arrow-sweep 2.4s ease-in-out infinite;
}
.af-arrow-1  { animation-delay: 0.0s; }
.af-arrow-2  { animation-delay: 0.27s; }
.af-arrow-3  { animation-delay: 0.54s; }
.af-arrow-4  { animation-delay: 0.81s; }
.af-arrow-5  { animation-delay: 1.08s; }
.af-arrow-6  { animation-delay: 1.35s; }
.af-arrow-7  { animation-delay: 1.62s; }
.af-arrow-8  { animation-delay: 1.89s; }
.af-arrow-9  { animation-delay: 2.16s; }

@keyframes arrow-sweep {
  0%   { opacity: 0;   transform: translateX(-12px); }
  30%  { opacity: 0.6; transform: translateX(0px); }
  70%  { opacity: 0.6; transform: translateX(8px); }
  100% { opacity: 0;   transform: translateX(20px); }
}

/* ─── Responsive ───────────────────────────────────────── */
@media (max-width: 768px) {
  .div-truck { height: 80px; }
  .div-truck__img { height: 45px; }
  .div-city  { height: 100px; }
  .af-arrow  { width: 20px; height: 20px; }
}
</style>

<script>
  // Scroll-driven truck position for the highway divider
  const truckImg = document.getElementById('divTruckImg') as HTMLImageElement | null;
  const truckWrap = document.getElementById('divTruckWrap');

  if (truckImg && truckWrap) {
    function updateTruck() {
      const rect = truckWrap!.getBoundingClientRect();
      const windowH = window.innerHeight;
      const progress = 1 - (rect.bottom / (windowH + rect.height));
      const clamped = Math.max(0, Math.min(1, progress));
      const containerW = truckWrap!.offsetWidth;
      const truckX = clamped * (containerW + 120) - 120;
      truckImg!.style.left = truckX + 'px';
      requestAnimationFrame(updateTruck);
    }
    requestAnimationFrame(updateTruck);
  }
</script>
