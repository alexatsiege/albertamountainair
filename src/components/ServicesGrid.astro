---
// ServicesGrid.astro — Exact match of v1 services-grid-preview.html
// 3-column grid, floating icons that bleed above card top, featured first card variant

interface Service {
  name: string;
  slug: string;
  tag?: string;
  desc?: string;
  featured?: boolean;
}

interface Props {
  services: Service[];
  eyebrow?: string;
  heading?: string;
  subheading?: string;
  phone: string;
}

const {
  services,
  eyebrow = 'Featured Services',
  heading = 'Heating & Cooling Solutions for Every Home',
  subheading = 'Fast, reliable HVAC services backed by experienced technicians.',
  phone,
} = Astro.props;

// Default service descriptions (used if not in contentcollection)
const defaultDescs: Record<string, string> = {
  'Heating & Cooling Installation': 'Upgrade your home with an efficient heating and cooling system — expert installation, Mass Save® rebates available.',
  'Heat Pump Installation': 'Install a modern heat pump system — efficient heating and cooling year-round, Mass Save® rebates available.',
  'Heating & Cooling Repair':       'System not working right? We diagnose and fix all major brands — experienced technicians, upfront pricing.',
  'Heat Pump Repair':       'Heat pump acting up? We diagnose and fix leading brands — experienced technicians, upfront pricing.',
  'Heating & Cooling Maintenance':  'Our Annual Maintenance Membership keeps your system efficient, safe, and ready for every season.',
  'Heat Pump Maintenance':  'Our Annual Maintenance Membership keeps your system efficient, safe, and ready for every season.',
};

// Mark the first service as featured if none flagged
const enriched = services.map((s, i) => ({
  ...s,
  featured: s.featured ?? (i === 0),
  desc: s.desc ?? defaultDescs[s.name] ?? 'Expert service backed by licensed, experienced technicians.',
}));
---

<section class="services-section" id="services">
  <div class="services-container">

    <div class="services-header">
      <span class="services-eyebrow">{eyebrow}</span>
      <h2 class="services-heading">{heading}</h2>
      <p class="services-subheading">{subheading}</p>
    </div>

    <div class="services-grid">
      {enriched.map((service) => (
        <a
          href={service.slug ? `/${service.slug}` : '#'}
          class={`service-card ${service.featured ? 'featured' : ''}`}
        >
          {service.featured && (
            <span class="featured-badge">⭐ Most Popular</span>
          )}
          <div class="service-icon-wrap">
            <!-- HVAC icon SVG -->
            <svg viewBox="0 0 24 24">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
          </div>
          <h3 class="service-title">{service.name}</h3>
          <p class="service-desc">{service.desc}</p>
          <div class="service-arrow">
            <svg viewBox="0 0 24 24">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>

<style>
.services-section {
  background: var(--color-bg);
  padding: var(--space-12) var(--space-4) var(--space-12);
}

.services-container {
  max-width: 1200px; margin: 0 auto;
}

/* ── Section header ── */
.services-header { text-align: center; margin-bottom: var(--space-10); }

.services-eyebrow {
  display: block; font-size: var(--text-xs); font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.1em;
  color: var(--color-primary); margin-bottom: var(--space-3);
}
.services-heading {
  font-family: var(--font-heading); font-size: var(--text-4xl); font-weight: 800;
  color: var(--color-text); line-height: 1.2;
  max-width: 560px; margin: 0 auto var(--space-3);
}
.services-subheading { font-size: var(--text-lg); color: var(--color-text-muted); }

/* ── Grid ── */
.services-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  padding-top: 44px; /* room for floating icons */
}

/* ── Card ── */
.service-card {
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-2xl);
  padding: calc(44px + var(--space-4)) var(--space-5) var(--space-5);
  display: flex; flex-direction: column; align-items: center;
  text-align: center;
  text-decoration: none; color: inherit;
  cursor: pointer; position: relative; overflow: visible;
  transition: box-shadow 250ms ease, transform 250ms ease, border-color 250ms ease;
  box-shadow: 0 1px 2px rgba(0,0,0,0.05);
  opacity: 0; transform: translateY(24px);
}
.service-card.is-visible {
  opacity: 1; transform: translateY(0);
  transition: opacity 0.5s ease, transform 0.5s ease,
              box-shadow 250ms ease, transform 250ms ease, border-color 250ms ease;
}
.service-card:hover {
  box-shadow: 0 12px 32px rgba(0,0,0,0.12);
  transform: translateY(-5px) !important;
  border-color: rgba(37,99,235,0.2);
}

/* ── Floating icon ── */
.service-icon-wrap {
  position: absolute; top: -44px; left: 50%; transform: translateX(-50%);
  width: 88px; height: 88px;
  border-radius: var(--radius-xl);
  background: var(--color-bg);
  border: 2px solid var(--color-border);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4px 20px rgba(37,99,235,0.12);
  transition: background 250ms ease, box-shadow 250ms ease, border-color 250ms ease;
  z-index: 2;
}
.service-icon-wrap svg {
  width: 38px; height: 38px;
  stroke: var(--color-primary); stroke-width: 1.75;
  fill: none; stroke-linecap: round; stroke-linejoin: round;
  transition: stroke 250ms ease;
}
.service-card:hover .service-icon-wrap {
  background: var(--color-primary-light);
  border-color: var(--color-primary);
  box-shadow: 0 8px 28px rgba(37,99,235,0.22);
}

/* ── Card text ── */
.service-title {
  font-family: var(--font-heading); font-size: var(--text-xl);
  font-weight: 700; color: var(--color-text); margin-bottom: var(--space-2);
}
.service-desc {
  font-size: var(--text-sm); color: var(--color-text-muted);
  line-height: 1.7; margin-bottom: var(--space-5); flex: 1;
}

/* ── Arrow ── */
.service-arrow {
  width: 40px; height: 40px;
  border-radius: 9999px; border: 1.5px solid var(--color-border);
  display: flex; align-items: center; justify-content: center;
  transition: all 250ms ease; margin-top: auto;
}
.service-arrow svg {
  width: 18px; height: 18px;
  stroke: var(--color-text-muted, #6B7280); stroke-width: 2;
  fill: none; stroke-linecap: round; stroke-linejoin: round;
  transition: stroke 250ms ease, transform 250ms ease;
}
.service-card:hover .service-arrow {
  background: var(--color-primary); border-color: var(--color-primary);
}
.service-card:hover .service-arrow svg {
  stroke: white; transform: translateX(2px);
}

/* ── Featured card ── */
.service-card.featured {
  background: var(--color-primary);
  border-color: var(--color-primary);
  box-shadow: 0 8px 32px rgba(37,99,235,0.28);
}
.service-card.featured .service-icon-wrap {
  background: #fff; border-color: rgba(255,255,255,0.8);
  box-shadow: 0 6px 24px rgba(37,99,235,0.25);
}
.service-card.featured .service-icon-wrap svg { stroke: var(--color-primary); }
.service-card.featured .service-title { color: #fff; }
.service-card.featured .service-desc { color: rgba(255,255,255,0.82); }
.service-card.featured .service-arrow { border-color: rgba(255,255,255,0.4); background: rgba(255,255,255,0.14); }
.service-card.featured .service-arrow svg { stroke: #fff; }

.service-card.featured:hover {
  box-shadow: 0 16px 48px rgba(37,99,235,0.4);
  border-color: var(--color-primary-dark); background: var(--color-primary-dark);
}
.service-card.featured:hover .service-icon-wrap { border-color: #fff; }
.service-card.featured:hover .service-arrow { background: #fff; border-color: #fff; }
.service-card.featured:hover .service-arrow svg { stroke: var(--color-primary); }

.featured-badge {
  display: inline-flex; align-items: center; gap: 5px;
  background: rgba(255,255,255,0.18); color: #fff;
  font-size: 0.65rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
  padding: 4px 10px; border-radius: 9999px;
  margin-bottom: var(--space-3); border: 1px solid rgba(255,255,255,0.3);
}

/* ── Responsive ── */
@media (max-width: 900px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 580px) {
  .services-section { padding: var(--space-8) var(--space-4); }
  .services-grid { grid-template-columns: 1fr; gap: 42px; }
  .services-heading { font-size: var(--text-2xl); }
}
</style>

<script>
  const cards = document.querySelectorAll('.service-card');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const i = Array.from(cards).indexOf(entry.target as HTMLElement);
        setTimeout(() => entry.target.classList.add('is-visible'), i * 90);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  cards.forEach(c => observer.observe(c));
</script>
