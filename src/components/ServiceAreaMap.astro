---
// ServiceAreaMap.astro — 50/50 dark split with Google Map iframe (All Power style)

interface Props {
  areas?: string[];
  clientName?: string;
  townName?: string;
  phone: string;
  mapEmbedUrl?: string;
}

const {
  areas = ['Calgary','Chestermere','Okotoks','Airdrie','Cochrane','Strathmore','High River'],
  clientName = 'Your Company',
  townName = 'Calgary',
  phone,
  mapEmbedUrl = 'https://www.google.com/maps?q=Bay%20214%20-%2011929%2040%20St%20SE%20Calgary%20AB%20T2Z%204M8&output=embed',
} = Astro.props;

const phoneRaw = phone.replace(/\D/g, '');
---

<section class="sam-section glass-reveal" id="service-area-map">
  <div class="sam-inner">

    <!-- Left: text + city grid -->
    <div class="sam-left">
      <span class="sam-eyebrow">
        <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
        </svg>
        Areas We Serve
      </span>
      <h2 class="sam-heading">Proudly Serving<br/>Your Community</h2>
      <div class="sam-rule"></div>
      <p class="sam-desc">We're a locally owned HVAC company serving Calgary and surrounding communities with reliable response times and straightforward service.</p>

      <div class="sam-city-grid">
        {areas.map(area => (
          <div class="sam-city">
            <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13" class="sam-pin">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
            {area}
          </div>
        ))}
      </div>

      <a href={`tel:${phoneRaw}`} class="sam-cta">
        Call {phone}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.52 2 2 0 0 1 3.6 1.36h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16.92z"/>
        </svg>
      </a>
    </div>

    <!-- Right: Google Map -->
    <div class="sam-right">
      <div class="sam-map-wrap">
        <iframe
          src={mapEmbedUrl}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`${clientName} Service Area Map`}
        ></iframe>
      </div>
    </div>

  </div>
</section>

<style>
.sam-section {
  background: #fff;
  padding: 80px 40px;
  position: relative;
  overflow: hidden;
  border-top: 1px solid #E5E7EB;
  border-bottom: 1px solid #E5E7EB;
}

.sam-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
  position: relative;
  z-index: 1;
}

.sam-left {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.sam-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 0.75rem;
  font-weight: 800;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-primary, #29b0e5);
}

.sam-heading {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 3.5vw, 2.8rem);
  font-weight: 900;
  line-height: 1.1;
  color: var(--color-heading);
}

.sam-rule {
  width: 48px;
  height: 4px;
  background: var(--color-accent, #f68a1e);
  border-radius: 4px;
}

.sam-desc {
  font-size: 0.95rem;
  color: var(--color-text-muted);
  line-height: 1.7;
  max-width: 420px;
}

.sam-city-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px 16px;
}

.sam-city {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--color-text);
}

.sam-pin {
  color: var(--color-primary, #29b0e5);
  flex-shrink: 0;
}

.sam-cta {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: var(--color-accent, #f68a1e);
  color: #fff;
  font-family: var(--font-heading);
  font-size: 0.95rem;
  font-weight: 800;
  padding: 14px 28px;
  border-radius: 50px;
  text-decoration: none;
  align-self: flex-start;
  transition: all 0.25s ease;
  box-shadow: 0 6px 20px rgba(246,138,30,0.3);
  margin-top: 4px;
}
.sam-cta:hover {
  background: #e07a15;
  transform: translateY(-2px);
  box-shadow: 0 10px 28px rgba(246,138,30,0.45);
}

.sam-right { position: relative; }

.sam-map-wrap {
  width: 100%;
  height: 440px;
  border-radius: 20px;
  overflow: hidden;
  border: 1px solid #E5E7EB;
  box-shadow: 0 8px 32px rgba(0,0,0,0.08);
}

.sam-map-wrap iframe {
  width: 100%;
  height: 100%;
  display: block;
}

@media (max-width: 900px) {
  .sam-section { padding: 60px 24px; }
  .sam-inner { grid-template-columns: 1fr; gap: 40px; }
  .sam-map-wrap { height: 320px; }
  .sam-cta { width: 100%; justify-content: center; }
  .sam-city-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>
