---
import { Image } from 'astro:assets';
import googleLogo from '../assets/Google__G__logo.svg (1).png';

interface Props {
  headline: string;
  subheadline: string;
  bullets?: string[];
  phone: string;
  navCTA: string;
  navCtaUrl: string;
  businessName: string;
  townName?: string;
  techCutout?: string;
  googleRating?: number;
  googleReviewCount?: number;
  heroReviews?: { text: string; name: string }[];
  promoStamp?: string;
  couponExpiry?: string;
  cornerSticker?: string;
  heroEyebrow?: string;
  logoSrc?: string;
  heroBg?: string;
  phoneFirst?: boolean;
  hideValueBar?: boolean;
}

const {
  headline, subheadline, bullets = [], phone, navCTA, navCtaUrl,
  businessName, townName = "your area", googleRating, googleReviewCount,
  promoStamp, heroEyebrow = "3,000+ 5-Star Reviews",
  logoSrc = '/_assets/one_way_air_logo.png',
  heroBg = '/_assets/ama-hero-bg.webp',
  phoneFirst = false,
  hideValueBar = false,
  couponExpiry,
} = Astro.props;

const animatedHeadline = headline.replace(/\|/g, '<br>');
---

<section class="hero" id="hero">
  <!-- Hero Background Photo -->
  <div class="hero-bg"><img src={heroBg} alt={`${businessName} HVAC team`} fetchpriority="high" decoding="async" /></div>
  
  <!-- Dark gradient overlay -->
  <div class="hero-overlay"></div>
  <!-- OWA Airflow accent — diagonal blue wash from bottom-left -->
  <div class="hero-air-accent"></div>
  <!-- OWA Ghost Logo — faint watermark anchored bottom-left, behind content -->
  <div class="hero-ghost-logo" aria-hidden="true">
    <img src={logoSrc} alt="" />
  </div>

  <div class="hero-inner">
    <div class="hero-content">

      {/* Slim PPC mode: no logo, no badge pills, no bullets — just the essentials */}
      {!phoneFirst && (
        <img src={logoSrc} alt={`${businessName} Logo`} class="hero-center-logo" />
      )}

      <!-- Brand Eyebrow -->
      <div class={phoneFirst ? "hero-eyebrow hero-eyebrow--slim" : "hero-eyebrow"}>
        {!phoneFirst && (
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        )}
        {heroEyebrow}
      </div>

      <h1 class="hero-headline" set:html={animatedHeadline} />

      <p class="hero-subheadline">
        {subheadline}
      </p>

      {/* Coupon — keep it, it converts */}
      {promoStamp && (
        <div class="hero-coupon-ticket">
          <div class="coupon-ticket-inner">
            <div class="coupon-dashed-border">
              <svg class="scissors-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"></circle><circle cx="6" cy="18" r="3"></circle><line x1="20" y1="4" x2="8.12" y2="15.88"></line><line x1="14.47" y1="14.48" x2="20" y2="20"></line><line x1="8.12" y1="8.12" x2="12" y2="12"></line></svg>
            <span class="coupon-text" set:html={promoStamp.replace(/\|/g, '<br><span class="coupon-highlight">')} />
              {couponExpiry && <p class="hero-coupon-fine-print">{couponExpiry}</p>}
            </div>
          </div>
        </div>
      )}

      {/* Bullets only shown in non-slim mode */}
      {!phoneFirst && bullets.length > 0 && (
        <ul class="hero-bullets">
          {bullets.map(bullet => (
            <li>
              <span class="bullet-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </span>
              {bullet}
            </li>
          ))}
        </ul>
      )}

      {/* Trust badges only in non-slim mode */}
      {!phoneFirst && googleRating && googleReviewCount && (
        <div class="hero-trust-badges">
          <div class="trust-badge">
            <div class="trust-badge-icon google">
              <Image src={googleLogo} alt="Google Reviews Badge" />
            </div>
            <div class="trust-badge-info">
              <span class="trust-badge-stars">★★★★★</span>
              <span class="trust-badge-label">{googleRating} · {googleReviewCount}+ Reviews</span>
            </div>
          </div>
          <div class="trust-badge">
            <div class="trust-badge-icon bbb">YYC</div>
            <div class="trust-badge-info">
              <span class="trust-badge-stars">★★★★★</span>
              <span class="trust-badge-label">Local Calgary Service</span>
            </div>
          </div>
        </div>
      )}

      <div class="hero-actions">
        {phoneFirst ? (
          <>
            <a href={`tel:${phone.replace(/\D/g, '')}`} class="hero-phone-cta btn btn-accent hero-phone-primary">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.52 2 2 0 0 1 3.6 1.36h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.73 16.92z"/>
              </svg>
              Call {phone}
            </a>
            <a href={navCtaUrl} class="hero-cta btn btn-ghost-white">
              {navCTA}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </>
        ) : (
          <>
            <a href={navCtaUrl} class="hero-cta btn btn-accent">
              {navCTA}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
            <a href={`tel:${phone.replace(/\D/g, '')}`} class="hero-phone-cta btn btn-primary">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.52 2 2 0 0 1 3.6 1.36h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.73 16.92z"/>
              </svg>
              {phone}
            </a>
          </>
        )}
      </div>
    </div>
  </div>


  <!-- Values bar — hidden on PPC repair pages to reduce noise -->
  {!hideValueBar && (
  <div class="value-props">
  <div class="value-props-inner">
    <div class="vp-item">
      <div class="vp-icon">
        <!-- Shield / Licensed -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="vp-svg"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      </div>
      <div class="vp-text">
        <span class="vp-title">Licensed & Insured</span>
        <span class="vp-desc">HVAC Certified Technicians</span>
      </div>
    </div>

    <div class="vp-item">
      <div class="vp-icon">
        <!-- Lightning / Fast -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="vp-svg"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
      </div>
      <div class="vp-text">
        <span class="vp-title">Fast Response</span>
        <span class="vp-desc">Same-Day Service Available</span>
      </div>
    </div>

    <div class="vp-item">
      <div class="vp-icon">
        <!-- Tag / Pricing -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="vp-svg"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
      </div>
      <div class="vp-text">
        <span class="vp-title">Transparent Pricing</span>
        <span class="vp-desc">Diagnostic Waived With Repair</span>
      </div>
    </div>

    <div class="vp-item">
      <div class="vp-icon">
        <!-- People / Homeowners -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="vp-svg"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </div>
      <div class="vp-text">
        <span class="vp-title">Calgary Homeowners</span>
        <span class="vp-desc">Heating & Cooling Help You Can Trust</span>
      </div>
    </div>

    <div class="vp-item">
      <div class="vp-icon">
        <!-- Heart / Community -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="vp-svg"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </div>
      <div class="vp-text">
        <span class="vp-title">Community First</span>
        <span class="vp-desc">We Sponsor Local Programs</span>
      </div>
    </div>
  </div>
  </div>
  )}
</section>

<style>
.hero {
  position: relative;
  min-height: 85vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  /* Brand blue — matches TeamSpotlight / HowItWorks exactly */
  background: linear-gradient(160deg, #0d3060 0%, #1a4a7a 55%, #0d3060 100%);
  padding-top: 110px;
  padding-bottom: 48px;
}

@media (max-width: 900px) {
  .hero { padding-top: 72px; }
}

.hero-bg {
  position: absolute; inset: 0;
  opacity: 0.75;
  overflow: hidden;
}
.hero-bg img {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center 30%;
  display: block;
}

/* Thin edge vignette — barely visible so image dominates */
.hero-overlay {
  position: absolute; inset: 0;
  background:
    linear-gradient(to bottom, rgba(13,48,96,0.45) 0%, rgba(13,48,96,0.10) 40%, rgba(13,48,96,0.55) 100%);
}

/* OWA Brand: Airflow accent — sweeping blue diagonal */
.hero-air-accent {
  position: absolute; inset: 0;
  background: linear-gradient(135deg,
    rgba(41, 176, 229, 0.18) 0%,
    rgba(45, 134, 200, 0.10) 40%,
    rgba(246, 138, 30, 0.06) 100%);
  pointer-events: none;
}

/* Remove duplicate .hero block — handled above */

/* ── Ghost logo watermark ── */
.hero-ghost-logo {
  position: absolute;
  bottom: -30%;
  left: -6%;
  height: 110%;
  aspect-ratio: 1 / 1;
  z-index: 1;
  pointer-events: none;
  overflow: visible;
}
.hero-ghost-logo img {
  width: 100%; height: 100%;
  object-fit: contain;
  object-position: bottom left;
  filter: brightness(0) invert(1) drop-shadow(0 0 24px rgba(41,176,229,0.7)) drop-shadow(0 0 60px rgba(41,176,229,0.4));
  opacity: 0.16;
  mix-blend-mode: luminosity;
}

.hero-air-accent {
  position: absolute; inset: 0;
  background: linear-gradient(135deg,
    rgba(41, 176, 229, 0.18) 0%,
    rgba(45, 134, 200, 0.10) 40%,
    rgba(246, 138, 30, 0.06) 100%);
  pointer-events: none;
}

.hero-inner {
  position: relative; z-index: 2;
  max-width: 860px;
  margin: 0 auto;
  padding: 80px 24px 32px;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  width: 100%;
}

/* Frosted glass backdrop — brand blue, readable over image */
.hero-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  gap: 0;
  background: rgba(13, 48, 96, 0.78);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(41, 176, 229, 0.20);
  border-radius: 20px;
  padding: 32px 40px;
  box-shadow: 0 8px 40px rgba(0,0,0,0.25), inset 0 1px 0 rgba(255,255,255,0.08);
}

.hero-center-logo {
  max-width: 130px;
  height: auto;
  margin-bottom: 12px;
  filter: drop-shadow(0 4px 16px rgba(0,0,0,0.4)) brightness(0) invert(1);
}

.hero-eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(246, 138, 30, 0.92);
  border: 1px solid rgba(255,255,255,0.4);
  border-radius: 100px;
  padding: 5px 16px;
  font-size: 0.78rem; font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: #fff;
  margin-bottom: 12px;
  box-shadow: 0 4px 16px rgba(246, 138, 30, 0.45);
}
.hero-eyebrow svg { color: #fff; width: 14px; height: 14px; }

/* Slim PPC variant — no pill, just a clean text label */
.hero-eyebrow--slim {
  background: none;
  border: none;
  border-radius: 0;
  padding: 0;
  box-shadow: none;
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: rgba(255,255,255,0.65);
  text-transform: uppercase;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.hero-eyebrow--slim::before {
  content: '';
  display: block;
  width: 28px;
  height: 2px;
  background: var(--color-accent);
  border-radius: 2px;
  flex-shrink: 0;
}

.hero-headline {
  font-family: var(--font-heading);
  font-size: clamp(2.4rem, 4.5vw, 3.8rem);
  font-weight: 900;
  line-height: 1.1;
  color: #fff;
  margin-bottom: 10px;
  text-shadow: 0 2px 20px rgba(0,0,0,0.4), 0 4px 40px rgba(0,0,0,0.2);
}

.hero-subheadline {
  font-size: 1rem;
  line-height: 1.5;
  margin-bottom: 12px;
  max-width: 640px;
  color: #f1f5f9;
  text-shadow: 0 1px 4px rgba(0,0,0,0.6);
  font-weight: 500;
}

/* Bullets: plain inline text row with separator dots */
.hero-bullets {
  list-style: none;
  display: flex; justify-content: center; align-items: center; gap: 0; flex-wrap: wrap;
  margin-bottom: 14px;
}

.hero-bullets li {
  display: flex; align-items: center;
  color: rgba(255,255,255,0.9);
  font-size: 0.92rem; font-weight: 600;
  background: none;
  padding: 4px 0;
  border-radius: 0;
  backdrop-filter: none;
  border: none;
  letter-spacing: 0.01em;
}

/* Dot separator between items */
.hero-bullets li:not(:last-child)::after {
  content: '·';
  margin: 0 10px;
  color: var(--color-accent);
  font-size: 1.2rem;
  font-weight: 900;
  line-height: 1;
}

.bullet-icon { display: none; }

.hero-trust-badges { 
  display: flex; justify-content: center; gap: 12px; flex-wrap: wrap;
  margin-bottom: 14px; 
}

.trust-badge {
  display: flex; align-items: center; gap: 10px;
  background: rgba(255,255,255,0.95);
  border-radius: 100px;
  padding: 6px 18px 6px 6px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.2);
}

.trust-badge-icon {
  width: 34px; height: 34px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-weight: 800; font-size: 0.75rem; color: #fff;
  flex-shrink: 0;
}
.trust-badge-icon.google { background: #fff; padding: 3px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
.trust-badge-icon.google img { width: 100%; height: 100%; object-fit: contain; display: block; }
.trust-badge-icon.bbb { background: #003F87; }

.trust-badge-info { text-align: left; }
.trust-badge-stars { color: #FBBC05; font-size: 0.72rem; display: block; line-height: 1; margin-bottom: 1px; }
.trust-badge-label { color: var(--color-text); font-size: 0.72rem; font-weight: 700; line-height: 1; }

.hero-actions {
  display: flex; justify-content: center; align-items: center; gap: 16px;
  flex-wrap: wrap;
}

.hero-cta { 
  font-size: 1rem; padding: 14px 32px; 
  border-radius: 100px;
  box-shadow: 0 8px 24px rgba(246, 138, 30, 0.45);
}
.hero-phone-cta {
  font-size: 1rem; padding: 14px 32px; 
  border-radius: 100px;
  background: var(--color-primary);
  color: white;
  border: 1px solid rgba(255,255,255,0.2);
  box-shadow: 0 8px 24px rgba(41, 176, 229, 0.35);
  text-decoration: none;
  font-family: var(--font-heading);
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  transition: all var(--transition-base);
}
.hero-phone-cta:hover {
  background: white;
  color: var(--color-primary);
  transform: translateY(-2px);
}

/* Phone-first PPC variant — big orange call button */
.hero-phone-primary {
  background: var(--color-accent) !important;
  border-color: transparent !important;
  box-shadow: 0 8px 28px rgba(246, 138, 30, 0.5) !important;
  font-size: 1.15rem !important;
  padding: 16px 36px !important;
  animation: hero-pulse 2.5s infinite;
}
.hero-phone-primary:hover {
  background: #e07a15 !important;
  color: white !important;
  box-shadow: 0 12px 36px rgba(246, 138, 30, 0.7) !important;
}
@keyframes hero-pulse {
  0%   { box-shadow: 0 8px 28px rgba(246,138,30,0.5); }
  50%  { box-shadow: 0 8px 40px rgba(246,138,30,0.8); }
  100% { box-shadow: 0 8px 28px rgba(246,138,30,0.5); }
}

/* Ghost-white secondary button */
.btn-ghost-white {
  background: rgba(255,255,255,0.12) !important;
  border: 1.5px solid rgba(255,255,255,0.35) !important;
  color: #fff !important;
  font-size: 1rem;
  padding: 14px 28px;
  border-radius: 100px;
  text-decoration: none;
  font-family: var(--font-heading);
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  backdrop-filter: blur(6px);
  transition: all 0.2s ease;
}
.btn-ghost-white:hover {
  background: rgba(255,255,255,0.22) !important;
  border-color: rgba(255,255,255,0.5) !important;
}

/* ── Value props bar ── */
.value-props {
  position: relative;
  z-index: 10;
  margin-top: 32px;
  padding: 0 24px;
  width: 100%;
}

.value-props-inner {
  max-width: 1200px; margin: 0 auto;
  background: #fff;
  border-radius: 16px;
  box-shadow: 0 12px 40px rgba(0,0,0,0.12), 0 4px 12px rgba(0,0,0,0.06);
  padding: 24px 32px;
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px;
  border: 1px solid rgba(0,0,0,0.05);
}

.vp-item { display: flex; align-items: center; }
.vp-item:not(:last-child) { border-right: 1px solid rgba(0,0,0,0.08); }

.vp-icon {
  width: 44px; height: 44px;
  background: var(--color-primary-ultra-light);
  color: var(--color-primary);
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  margin-right: 14px;
  flex-shrink: 0;
}
.vp-svg { width: 22px; height: 22px; color: var(--color-primary); }

.vp-text { display: flex; flex-direction: column; }
.vp-title { font-size: 0.9rem; font-weight: 800; color: var(--color-text); font-family: var(--font-heading); }
.vp-desc  { font-size: 0.78rem; color: var(--color-text-muted); margin-top: 1px; }

/* Responsive */
@media (max-width: 1024px) {
  .value-props-inner { grid-template-columns: repeat(2, 1fr); gap: 24px; }
}

/* Tablet */
@media (max-width: 900px) {
  .hero-inner { padding: 72px 20px 28px; }
  .hero-center-logo { max-width: 110px; margin-bottom: 10px; }
  .hero-headline { font-size: 2rem; }
}

/* Mobile */
@media (max-width: 768px) {
  .hero { min-height: 100dvh; }
  .hero-inner { padding: 68px 16px 24px; }
  .hero-center-logo { max-width: 90px; margin-bottom: 8px; }
  .hero-eyebrow { font-size: 0.72rem; padding: 4px 14px; margin-bottom: 8px; }
  .hero-headline { font-size: clamp(1.5rem, 6vw, 2rem); margin-bottom: 8px; }
  .hero-subheadline { font-size: 0.9rem; margin-bottom: 10px; }
  .hero-bullets { gap: 6px; margin-bottom: 10px; }
  .hero-bullets li { font-size: 0.75rem; padding: 4px 10px; }
  .hero-trust-badges { margin-bottom: 10px; }
  .trust-badge { padding: 5px 14px 5px 5px; }
  .trust-badge-icon { width: 28px; height: 28px; }
  .hero-actions { flex-direction: column; width: 100%; gap: 10px; }
  .hero-cta, .hero-phone-cta { width: 100%; justify-content: center; font-size: 0.95rem; padding: 13px 20px; }
  .value-props { margin-top: 16px; }
}

@media (max-width: 640px) {
  .value-props-inner { grid-template-columns: 1fr; }
  .vp-item:not(:last-child) { border-right: none; border-bottom: 1px solid rgba(0,0,0,0.08); padding-bottom: 16px; }
}

/* ── Coupon Ticket ── */
.hero-coupon-ticket {
  width: 100%; max-width: 460px; margin: 0 auto 12px auto;
  background: rgba(255, 255, 255, 0.95);
