---
// OWA Animation Preview Page — all 10 concepts
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Your Company — Animation Concepts Preview</title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;600;700;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --blue: #29b0e5; --blue-dark: #2d86c8; --orange: #f68a1e;
      --bg: #04111f; --card-bg: #0a1e33; --text: #fff;
    }
    body { background: var(--bg); color: var(--text); font-family: 'Barlow', sans-serif; }

    header {
      text-align: center; padding: 60px 24px 40px;
      border-bottom: 1px solid rgba(41,176,229,0.2);
    }
    header h1 { font-size: 2.8rem; font-weight: 900; color: var(--blue); }
    header p { color: rgba(255,255,255,0.6); margin-top: 8px; font-size: 1.05rem; }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(520px, 1fr));
      gap: 32px; padding: 48px 40px;
      max-width: 1400px; margin: 0 auto;
    }

    .card {
      background: var(--card-bg);
      border: 1px solid rgba(41,176,229,0.15);
      border-radius: 20px; overflow: hidden;
    }
    .card-demo {
      position: relative; height: 300px; overflow: hidden;
      background: #060f1c;
    }
    .card-label {
      padding: 20px 24px;
      border-top: 1px solid rgba(41,176,229,0.12);
    }
    .card-num {
      font-size: 0.72rem; font-weight: 700; letter-spacing: 2px;
      color: var(--orange); text-transform: uppercase; margin-bottom: 4px;
    }
    .card-title { font-size: 1.2rem; font-weight: 800; margin-bottom: 6px; }
    .card-desc { font-size: 0.85rem; color: rgba(255,255,255,0.55); line-height: 1.5; }

    /* ════════════════════════════════════
       CONCEPT 1 — Scroll-Draw Arrow Border
       ════════════════════════════════════ */
    .c1-box {
      position: absolute; inset: 30px;
      background: rgba(41,176,229,0.05);
      border-radius: 16px;
      display: flex; align-items: center; justify-content: center;
    }
    .c1-box span { font-size: 1.1rem; font-weight: 700; color: rgba(255,255,255,0.7); }
    .c1-svg {
      position: absolute; inset: 0; width: 100%; height: 100%;
      pointer-events: none;
    }
    .c1-path {
      fill: none; stroke-width: 3; stroke-linecap: round; stroke-linejoin: round;
    }
    .c1-orange { stroke: var(--orange); }
    .c1-blue   { stroke: var(--blue); }

    /* ════════════════════════════════════
       CONCEPT 2 — Airflow Sweep Dividers
       ════════════════════════════════════ */
    .c2-wrap {
      position: absolute; inset: 0;
      display: flex; flex-direction: column;
      justify-content: space-evenly; overflow: hidden;
    }
    .c2-lane {
      display: flex; align-items: center; white-space: nowrap;
      animation: c2-sweep 4s linear infinite;
      opacity: 0.7;
    }
    .c2-lane:nth-child(2) { animation-duration: 5.5s; animation-delay: -1s; opacity: 0.45; }
    .c2-lane:nth-child(3) { animation-duration: 3.5s; animation-delay: -2.5s; opacity: 0.3; }
    .c2-lane:nth-child(4) { animation-duration: 6s; animation-delay: -0.5s; opacity: 0.5; }
    .c2-lane:nth-child(5) { animation-duration: 4.5s; animation-delay: -3s; opacity: 0.35; }
    .c2-chevron { font-size: 1.6rem; font-weight: 900; color: var(--blue); margin-right: 18px; }
    .c2-lane:nth-child(even) .c2-chevron { color: var(--orange); }
    @keyframes c2-sweep {
      0% { transform: translateX(-60%); }
      100% { transform: translateX(0%); }
    }

    /* ════════════════════════════════════
       CONCEPT 3 — Hero Wind Vortex
       ════════════════════════════════════ */
    #c3-canvas { position: absolute; inset: 0; width: 100%; height: 100%; }

    /* ════════════════════════════════════
       CONCEPT 4 — Scroll Arrow River
       ════════════════════════════════════ */
    #c4-canvas { position: absolute; inset: 0; width: 100%; height: 100%; }
    .c4-label {
      position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
      text-align: center;
    }
    .c4-label p { font-size: 0.8rem; color: rgba(255,255,255,0.4); margin-top: 6px; }

    /* ════════════════════════════════════
       CONCEPT 5 — Pulsing Chevron Ring
       ════════════════════════════════════ */
    .c5-center {
      position: absolute; inset: 0;
      display: flex; align-items: center; justify-content: center;
    }
    .c5-ring {
      position: absolute;
      border-radius: 50%;
      border: 2px solid var(--blue);
      animation: c5-pulse 3s ease-out infinite;
    }
    .c5-ring:nth-child(1) { width: 80px; height: 80px; animation-delay: 0s; }
    .c5-ring:nth-child(2) { width: 80px; height: 80px; animation-delay: 0.6s; border-color: var(--orange); }
    .c5-ring:nth-child(3) { width: 80px; height: 80px; animation-delay: 1.2s; }
    .c5-ring:nth-child(4) { width: 80px; height: 80px; animation-delay: 1.8s; border-color: var(--orange); }
    .c5-core {
      width: 64px; height: 64px; border-radius: 50%;
      background: var(--blue); display: flex; align-items: center; justify-content: center;
      font-size: 1.6rem; font-weight: 900; color: #fff; z-index: 2;
      box-shadow: 0 0 24px rgba(41,176,229,0.6);
    }
    @keyframes c5-pulse {
      0%   { transform: scale(1); opacity: 0.8; }
      100% { transform: scale(5); opacity: 0; }
    }

    /* ════════════════════════════════════
       CONCEPT 6 — Particle Arrow Field
       ════════════════════════════════════ */
    #c6-canvas { position: absolute; inset: 0; width: 100%; height: 100%; }

    /* ════════════════════════════════════
       CONCEPT 7 — Air Duct Grid
       ════════════════════════════════════ */
    .c7-grid {
      position: absolute; inset: 0;
      display: grid; grid-template-columns: repeat(5, 1fr); grid-template-rows: repeat(4, 1fr);
      gap: 8px; padding: 20px;
    }
    .c7-duct {
      border: 2px solid rgba(41,176,229,0.3);
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden; position: relative; background: rgba(41,176,229,0.04);
    }
    .c7-arrow {
      position: absolute; white-space: nowrap;
      font-size: 1.2rem; font-weight: 900;
      color: var(--blue);
      animation: c7-flow 2s linear infinite;
    }
    .c7-duct:nth-child(even) .c7-arrow { color: var(--orange); animation-direction: reverse; animation-duration: 2.8s; }
    .c7-duct:nth-child(3n) .c7-arrow { animation-duration: 1.6s; }
    @keyframes c7-flow {
      0%   { transform: translateX(-100%); }
      100% { transform: translateX(100%); }
    }

    /* ════════════════════════════════════
       CONCEPT 8 — Kinetic Arrow Wave
       ════════════════════════════════════ */
    #c8-canvas { position: absolute; inset: 0; width: 100%; height: 100%; }

    /* ════════════════════════════════════
       CONCEPT 9 — Neon Arrow Trail
       ════════════════════════════════════ */
    #c9-canvas { position: absolute; inset: 0; width: 100%; height: 100%; cursor: crosshair; }
    .c9-hint {
      position: absolute; inset: 0;
      display: flex; align-items: center; justify-content: center;
      pointer-events: none;
    }
    .c9-hint p { font-size: 0.85rem; color: rgba(255,255,255,0.35); }

    /* ════════════════════════════════════
       CONCEPT 10 — Blueprint HVAC Flow
       ════════════════════════════════════ */
    #c10-canvas { position: absolute; inset: 0; width: 100%; height: 100%; }
  </style>
</head>
