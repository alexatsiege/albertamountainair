<script>
// ═══════════════════════════════════════════
// CONCEPT 1 — Scroll-Draw Arrow Border
// ═══════════════════════════════════════════
(function() {
  const paths = ['c1-p1','c1-p2','c1-p3','c1-p4'];
  paths.forEach(id => {
    const el = document.getElementById(id);
    if (!el) return;
    const len = el.getTotalLength ? el.getTotalLength() : 200;
    el.style.strokeDasharray = len;
    el.style.strokeDashoffset = len;
    el.style.transition = 'stroke-dashoffset 1.2s cubic-bezier(0.4,0,0.2,1)';
  });
  const demo = document.getElementById('c1-demo');
  const io = new IntersectionObserver(entries => {
    if (entries[0].isIntersecting) {
      paths.forEach((id, i) => {
        const el = document.getElementById(id);
        if (!el) return;
        setTimeout(() => { el.style.strokeDashoffset = '0'; }, i * 150);
      });
      io.disconnect();
    }
  });
  if (demo) io.observe(demo);
})();

// ═══════════════════════════════════════════
// CONCEPT 3 — Wind Vortex
// ═══════════════════════════════════════════
(function() {
  const canvas = document.getElementById('c3-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let W, H, raf;
  function resize() { W = canvas.width = canvas.offsetWidth; H = canvas.height = canvas.offsetHeight; }
  resize();
  window.addEventListener('resize', resize);
  const rings = [
    { r: 40, n: 6, speed: 0.004, color: '#29b0e5', opacity: 0.8 },
    { r: 80, n: 10, speed: 0.003, color: '#f68a1e', opacity: 0.6 },
    { r: 125, n: 14, speed: 0.002, color: '#29b0e5', opacity: 0.45 },
    { r: 170, n: 18, speed: 0.0015, color: '#f68a1e', opacity: 0.3 },
  ];
  let t = 0;
  function drawArrow(ctx, x, y, angle, size, color, opacity) {
    ctx.save();
    ctx.translate(x, y);
    ctx.rotate(angle + Math.PI / 2);
    ctx.globalAlpha = opacity;
    ctx.strokeStyle = color;
    ctx.lineWidth = 2;
    ctx.lineCap = 'round';
    ctx.beginPath();
    ctx.moveTo(0, -size);
    ctx.lineTo(0, size);
    ctx.moveTo(-size * 0.5, size * 0.2);
    ctx.lineTo(0, size);
    ctx.lineTo(size * 0.5, size * 0.2);
    ctx.stroke();
    ctx.restore();
  }
  function frame() {
    ctx.clearRect(0, 0, W, H);
    const cx = W / 2, cy = H / 2;
    rings.forEach(ring => {
      for (let i = 0; i < ring.n; i++) {
        const baseAngle = (i / ring.n) * Math.PI * 2;
        const angle = baseAngle + t * ring.speed * 1000;
        const x = cx + Math.cos(angle) * ring.r;
        const y = cy + Math.sin(angle) * ring.r;
        drawArrow(ctx, x, y, angle, 8, ring.color, ring.opacity);
      }
    });
    t += 0.016;
    raf = requestAnimationFrame(frame);
  }
  frame();
})();

// ═══════════════════════════════════════════
// CONCEPT 4 — Scroll Arrow River (animated demo)
// ═══════════════════════════════════════════
(function() {
  const canvas = document.getElementById('c4-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let W, H;
  function resize() { W = canvas.width = canvas.offsetWidth; H = canvas.height = canvas.offsetHeight; }
  resize();
  window.addEventListener('resize', resize);
  let progress = 0, dir = 1;
  function getPath(w, h) {
    const p = new Path2D();
    p.moveTo(0, h * 0.6);
    p.bezierCurveTo(w * 0.25, h * 0.8, w * 0.5, h * 0.1, w * 0.75, h * 0.5);
    p.bezierCurveTo(w * 0.88, h * 0.7, w, h * 0.4, w, h * 0.4);
    return p;
  }
  function frame() {
    ctx.clearRect(0, 0, W, H);
    // Draw faint full path
    ctx.save();
    ctx.strokeStyle = 'rgba(41,176,229,0.12)';
    ctx.lineWidth = 4;
    ctx.setLineDash([8, 12]);
    ctx.beginPath();
    ctx.moveTo(0, H * 0.6);
    ctx.bezierCurveTo(W * 0.25, H * 0.8, W * 0.5, H * 0.1, W * 0.75, H * 0.5);
    ctx.bezierCurveTo(W * 0.88, H * 0.7, W, H * 0.4, W, H * 0.4);
    ctx.stroke();
    ctx.restore();
    // Animated glowing head
    const steps = 80;
    const drawn = Math.floor(progress * steps);
    for (let i = 0; i < drawn; i++) {
      const t0 = i / steps, t1 = (i + 1) / steps;
      const pt0 = getPointOnCurve(W, H, t0);
      const pt1 = getPointOnCurve(W, H, t1);
      const alpha = (i / drawn);
      ctx.strokeStyle = `rgba(41,176,229,${alpha * 0.9})`;
      ctx.lineWidth = 3 + alpha * 2;
      ctx.shadowColor = '#29b0e5';
      ctx.shadowBlur = alpha * 16;
      ctx.beginPath();
      ctx.moveTo(pt0.x, pt0.y);
      ctx.lineTo(pt1.x, pt1.y);
      ctx.stroke();
      ctx.shadowBlur = 0;
    }
    // Arrow head at tip
    if (drawn > 1) {
      const tip = getPointOnCurve(W, H, drawn / steps);
      const prev = getPointOnCurve(W, H, (drawn - 1) / steps);
      const angle = Math.atan2(tip.y - prev.y, tip.x - prev.x);
      ctx.save();
      ctx.translate(tip.x, tip.y);
      ctx.rotate(angle);
      ctx.fillStyle = '#29b0e5';
      ctx.shadowColor = '#29b0e5';
      ctx.shadowBlur = 20;
      ctx.beginPath();
      ctx.moveTo(12, 0);
      ctx.lineTo(-8, -7);
      ctx.lineTo(-8, 7);
      ctx.closePath();
      ctx.fill();
      ctx.restore();
    }
    progress += dir * 0.004;
    if (progress > 1) dir = -1;
    if (progress < 0) dir = 1;
    requestAnimationFrame(frame);
  }
  function getPointOnCurve(w, h, t) {
    // 2 bezier segments joined
    let x, y;
    if (t <= 0.5) {
      const s = t * 2;
      x = cubicBezier(0, w*0.25, w*0.5, w*0.75, s);
      y = cubicBezier(h*0.6, h*0.8, h*0.1, h*0.5, s);
    } else {
      const s = (t - 0.5) * 2;
      x = cubicBezier(w*0.75, w*0.88, w, w, s);
      y = cubicBezier(h*0.5, h*0.7, h*0.4, h*0.4, s);
    }
    return { x, y };
  }
  function cubicBezier(p0, p1, p2, p3, t) {
    const mt = 1 - t;
    return mt*mt*mt*p0 + 3*mt*mt*t*p1 + 3*mt*t*t*p2 + t*t*t*p3;
  }
  frame();
})();

// ═══════════════════════════════════════════
// CONCEPT 6 — Particle Arrow Field
// ═══════════════════════════════════════════
(function() {
  const canvas = document.getElementById('c6-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let W, H;
  function resize() { W = canvas.width = canvas.offsetWidth; H = canvas.height = canvas.offsetHeight; }
  resize();
  window.addEventListener('resize', resize);
  const particles = Array.from({ length: 80 }, () => ({
    x: Math.random() * 600, y: Math.random() * 300,
    speed: 0.5 + Math.random() * 1.5,
    size: 5 + Math.random() * 10,
    opacity: 0.2 + Math.random() * 0.6,
    color: Math.random() > 0.7 ? '#f68a1e' : '#29b0e5'
  }));
  function drawArrowParticle(p) {
    ctx.save();
    ctx.globalAlpha = p.opacity;
    ctx.strokeStyle = p.color;
    ctx.lineWidth = 1.5;
    ctx.lineCap = 'round';
    ctx.translate(p.x, p.y);
    ctx.beginPath();
    ctx.moveTo(-p.size, 0); ctx.lineTo(p.size, 0);
    ctx.moveTo(p.size * 0.3, -p.size * 0.4); ctx.lineTo(p.size, 0); ctx.lineTo(p.size * 0.3, p.size * 0.4);
    ctx.stroke();
    ctx.restore();
  }
  function frame() {
    ctx.fillStyle = 'rgba(6,15,28,0.3)';
    ctx.fillRect(0, 0, W, H);
    particles.forEach(p => {
      drawArrowParticle(p);
      p.x += p.speed;
      if (p.x > W + 20) { p.x = -20; p.y = Math.random() * H; }
    });
    requestAnimationFrame(frame);
  }
  frame();
})();

// ═══════════════════════════════════════════
// CONCEPT 8 — Kinetic Arrow Wave
// ═══════════════════════════════════════════
(function() {
  const canvas = document.getElementById('c8-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let W, H;
  function resize() { W = canvas.width = canvas.offsetWidth; H = canvas.height = canvas.offsetHeight; }
  resize();
  window.addEventListener('resize', resize);
  let t = 0;
  function frame() {
    ctx.clearRect(0, 0, W, H);
    const rows = 3, spacing = H / (rows + 1);
    for (let row = 0; row < rows; row++) {
      const baseY = spacing * (row + 1);
      const cols = 12;
      for (let col = 0; col < cols; col++) {
        const x = (col / cols) * W + (t * 60 % (W / cols));
        const wave = Math.sin(t * 2 + col * 0.8 + row * 1.2) * 30;
        const y = baseY + wave;
        const angle = Math.atan2(
          Math.sin(t * 2 + (col + 0.1) * 0.8 + row * 1.2) * 30 - wave,
          W / cols
        );
        const isOrange = (row + col) % 3 === 0;
        const alpha = 0.3 + 0.4 * Math.abs(Math.sin(t + col * 0.5));
        ctx.save();
        ctx.translate(x, y);
        ctx.rotate(angle);
        ctx.globalAlpha = alpha;
        ctx.strokeStyle = isOrange ? '#f68a1e' : '#29b0e5';
        ctx.lineWidth = 2;
        ctx.lineCap = 'round';
        const s = 14;
        ctx.beginPath();
        ctx.moveTo(-s, 0); ctx.lineTo(s, 0);
        ctx.moveTo(s * 0.3, -s * 0.45); ctx.lineTo(s, 0); ctx.lineTo(s * 0.3, s * 0.45);
        ctx.stroke();
        ctx.restore();
      }
    }
    t += 0.016;
    requestAnimationFrame(frame);
  }
  frame();
})();

// ═══════════════════════════════════════════
// CONCEPT 9 — Neon Arrow Trail
// ═══════════════════════════════════════════
(function() {
  const canvas = document.getElementById('c9-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let W, H;
  function resize() { W = canvas.width = canvas.offsetWidth; H = canvas.height = canvas.offsetHeight; }
  resize();
  window.addEventListener('resize', resize);
  const trail = [];
  canvas.parentElement.addEventListener('mousemove', e => {
    const rect = canvas.getBoundingClientRect();
    trail.push({ x: e.clientX - rect.left, y: e.clientY - rect.top, t: Date.now() });
    if (trail.length > 30) trail.shift();
  });
  function frame() {
    ctx.clearRect(0, 0, W, H);
    for (let i = 1; i < trail.length; i++) {
      const p0 = trail[i - 1], p1 = trail[i];
      const age = (Date.now() - p1.t) / 800;
      if (age > 1) continue;
      const alpha = 1 - age;
      const angle = Math.atan2(p1.y - p0.y, p1.x - p0.x);
      const s = 10 * alpha;
      ctx.save();
      ctx.translate(p1.x, p1.y);
      ctx.rotate(angle);
      ctx.globalAlpha = alpha;
      ctx.strokeStyle = i % 2 === 0 ? '#29b0e5' : '#f68a1e';
      ctx.shadowColor = i % 2 === 0 ? '#29b0e5' : '#f68a1e';
      ctx.shadowBlur = 12;
      ctx.lineWidth = 2;
      ctx.lineCap = 'round';
      ctx.beginPath();
      ctx.moveTo(-s, 0); ctx.lineTo(s, 0);
      ctx.moveTo(s * 0.3, -s * 0.5); ctx.lineTo(s, 0); ctx.lineTo(s * 0.3, s * 0.5);
      ctx.stroke();
      ctx.restore();
    }
    requestAnimationFrame(frame);
  }
  frame();
})();

// ═══════════════════════════════════════════
// CONCEPT 10 — Blueprint HVAC Flow
// ═══════════════════════════════════════════
(function() {
  const canvas = document.getElementById('c10-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let W, H;
  function resize() { W = canvas.width = canvas.offsetWidth; H = canvas.height = canvas.offsetHeight; }
  resize();
  window.addEventListener('resize', resize);
  let t = 0;
  // Define duct segments
  function getDucts(w, h) {
    return [
      { x1: w*0.1, y1: h*0.3, x2: w*0.4, y2: h*0.3 },
      { x1: w*0.4, y1: h*0.3, x2: w*0.4, y2: h*0.7 },
      { x1: w*0.4, y1: h*0.7, x2: w*0.9, y2: h*0.7 },
      { x1: w*0.6, y1: h*0.3, x2: w*0.9, y2: h*0.3 },
      { x1: w*0.6, y1: h*0.3, x2: w*0.6, y2: h*0.5 },
    ];
  }
  function drawDuctArrow(x, y, angle, alpha, color) {
    ctx.save();
    ctx.translate(x, y); ctx.rotate(angle);
    ctx.globalAlpha = alpha;
    ctx.strokeStyle = color;
    ctx.shadowColor = color; ctx.shadowBlur = 8;
    ctx.lineWidth = 2; ctx.lineCap = 'round';
    ctx.beginPath();
    ctx.moveTo(-8, 0); ctx.lineTo(8, 0);
    ctx.moveTo(2, -5); ctx.lineTo(8, 0); ctx.lineTo(2, 5);
    ctx.stroke();
    ctx.restore();
  }
  function frame() {
    ctx.clearRect(0, 0, W, H);
    // Grid
    ctx.strokeStyle = 'rgba(41,176,229,0.06)';
    ctx.lineWidth = 1;
    for (let x = 0; x < W; x += 30) { ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke(); }
    for (let y = 0; y < H; y += 30) { ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke(); }
    const ducts = getDucts(W, H);
    // Draw ducts
    ducts.forEach(d => {
      ctx.strokeStyle = 'rgba(41,176,229,0.35)';
      ctx.lineWidth = 12; ctx.lineCap = 'round';
      ctx.beginPath(); ctx.moveTo(d.x1, d.y1); ctx.lineTo(d.x2, d.y2); ctx.stroke();
      ctx.strokeStyle = 'rgba(6,15,28,0.8)';
      ctx.lineWidth = 8;
      ctx.beginPath(); ctx.moveTo(d.x1, d.y1); ctx.lineTo(d.x2, d.y2); ctx.stroke();
    });
    // Animate arrows along ducts
    ducts.forEach((d, di) => {
      const dx = d.x2 - d.x1, dy = d.y2 - d.y1;
      const len = Math.sqrt(dx*dx + dy*dy);
      const angle = Math.atan2(dy, dx);
      const spacing = 40;
      const count = Math.floor(len / spacing);
      const offset = (t * 40 + di * 15) % spacing;
      for (let i = 0; i <= count; i++) {
        const dist = i * spacing + offset;
        if (dist > len) break;
        const px = d.x1 + (dx / len) * dist;
        const py = d.y1 + (dy / len) * dist;
        const fade = Math.sin((dist / len) * Math.PI);
        const color = di % 2 === 0 ? '#29b0e5' : '#f68a1e';
        drawDuctArrow(px, py, angle, fade * 0.9, color);
      }
    });
    // Corner joints
    [[W*0.4,H*0.3],[W*0.4,H*0.7],[W*0.6,H*0.3]].forEach(([x,y]) => {
      ctx.beginPath();
      ctx.arc(x, y, 7, 0, Math.PI*2);
      ctx.fillStyle = 'rgba(41,176,229,0.6)';
      ctx.fill();
    });
    t += 0.016;
    requestAnimationFrame(frame);
  }
  frame();
})();
</script>
