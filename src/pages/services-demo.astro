---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

import ServicesCategorizedSplit from '../components/ServicesCategorizedSplit.astro';
import ServicesCategorized from '../components/ServicesCategorized.astro';
import ServicesGrid from '../components/ServicesGrid.astro';

const clients = await getCollection('clients');
const clientEntry = clients[0];
const cfg = clientEntry?.data;
---

<BaseLayout 
  title={`Services Layout Demos | ${cfg.businessName}`}
  description="Showcasing layout variations."
  client={cfg}
>
  <div style="padding: 140px 24px 60px; text-align: center; background: var(--color-primary-dark); color: white;">
    <h1 style="font-size: clamp(2.5rem, 5vw, 4rem); font-family: var(--font-heading); margin-bottom: 16px;">Service Module Sandbox</h1>
    <p style="font-size: 1.2rem; color: #f1f5f9;">A side-by-side comparison of the 3 different Service UI architectures.</p>
  </div>

  <!-- Design 1: Split -->
  <div style="padding: 60px 24px 20px; background: #fff; text-align: center;">
    <span style="display: inline-block; background: var(--color-accent); color: #fff; padding: 6px 16px; border-radius: 100px; font-weight: bold; font-size: 0.9rem; margin-bottom: 16px;">Design 1</span>
    <h2 style="color: var(--color-heading); font-size: 2.2rem; font-family: var(--font-heading);">The "70/30 Split Card Grid"</h2>
    <p style="color: var(--color-text-muted);">The layout currently live on the site. High density, hyper-visual, minimal vertical scrolling.</p>
  </div>
  <div style="border-bottom: 4px dashed #e2e8f0; padding-bottom: 80px;">
    <ServicesCategorizedSplit 
      headline="Top-Rated HVAC & Plumbing"
      subheadline="Here is what we fix."
      services={cfg.services}
    />
  </div>

  <!-- Design 2: Accordions -->
  <div style="padding: 100px 24px 20px; background: #fff; text-align: center;">
    <span style="display: inline-block; background: var(--color-primary); color: #fff; padding: 6px 16px; border-radius: 100px; font-weight: bold; font-size: 0.9rem; margin-bottom: 16px;">Design 2</span>
    <h2 style="color: var(--color-heading); font-size: 2.2rem; font-family: var(--font-heading);">The "Full-Width Accordions"</h2>
    <p style="color: var(--color-text-muted);">Heavy text injection, interactive drop-downs, excellent for storing deep SEO paragraphs.</p>
  </div>
  <div style="border-bottom: 4px dashed #e2e8f0; padding-bottom: 80px;">
    <!-- Note: Original Jay Moody utilized background layers. -->
    <ServicesCategorized 
      headline="Our Complete Services"
      subheadline="Click to expand."
      services={cfg.services}
    />
  </div>

  <!-- Design 3: Grid -->
  <div style="padding: 100px 24px 20px; background: #fff; text-align: center;">
    <span style="display: inline-block; background: #1e293b; color: #fff; padding: 6px 16px; border-radius: 100px; font-weight: bold; font-size: 0.9rem; margin-bottom: 16px;">Design 3</span>
    <h2 style="color: var(--color-heading); font-size: 2.2rem; font-family: var(--font-heading);">The "Basic Box Grid"</h2>
    <p style="color: var(--color-text-muted);">Simple, clean mapping of all services into standard cards. Ideal for sub-pages.</p>
  </div>
  <div style="padding-bottom: 120px;">
    <ServicesGrid 
      headline="Everything We Offer"
      subheadline="No layout tricks, just the data."
      services={cfg.services}
      clientName={cfg.businessName}
    />
  </div>

</BaseLayout>
